//ELIMINA LOS ESPACIOS EN BLANCO DE LA IZQUIERDA DE UN CAMPO
function ltrim(tira)
{
var CARACTER="",HILERA=""
 if (tira.name)
   {VALOR=tira.value}
  else
   {VALOR=tira}
 
HILERA=VALOR
INICIO = VALOR.lastIndexOf(" ")
if(INICIO>-1){
  for (var i=0; i<VALOR.length; i++)
   { 
     CARACTER=VALOR.substring(i,i+1);
     if (CARACTER!=" ")
     {
       HILERA = VALOR.substring(i,VALOR.length)
       i = VALOR.length      
     }
  }
}
 return HILERA
}


function trim(tira)
 {return ltrim(rtrim(tira))}

//ELIMINA LOS ESPACIOS EN BLANCO DE LA DERECHA DE UN CAMPO 
function rtrim(tira)
{
if (tira.name)
  {VALOR=tira.value}
  else
  {VALOR=tira}
var CARACTER=""
var HILERA=VALOR
INICIO = VALOR.lastIndexOf(" ")
   if(INICIO>-1){
     for(var i=VALOR.length; i>0; i--){  
         CARACTER= VALOR.substring(i,i-1)
         if(CARACTER==" ")
            HILERA = VALOR.substring(0,i-1)
         else
            i=-200
      }
   }
return HILERA
}

