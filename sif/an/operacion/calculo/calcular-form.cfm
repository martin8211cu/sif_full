<cffunction name="sbListaProgramados" output="true" returntype="void">
	<cfargument name="Tipo" 	type="string" required="yes">
	<cfargument name="Titulo" 	type="string" required="yes">

	<cfif mid(Arguments.Tipo,1,1) EQ "D">
		<cfset LvarTipoDistribucion =  mid(Arguments.Tipo,2,1)>
	<cfelse>
		<cfset LvarTipoDistribucion =  "">
	</cfif>
	
	<cfparam name="url.chkND" default="0">
	<cfif Arguments.Tipo EQ "DN">
		<table width="98%" cellpadding="0" cellspacing="0" align="center">
			<tr>
				<td colspan="9" align="center" bgcolor="##CCCCCC" style="padding:3px; ">
					<strong>#Arguments.Titulo#</strong>
				</td>
			</tr>
			<tr>
				<td>&nbsp;</td>
				<td colspan="8">
					<input type="checkbox" name="chkND" value="1" <cfif url.chkND EQ "1"> checked </cfif>
							 onclick="location.href='index.cfm?GAid=#URLEncodedFormat(url.GAid)#&msg=#msg#&AnexoId=#URLEncodedFormat(url.AnexoId)#&ACid=#ACid#&ACano=#url.ACano#&ACmes=#url.ACmes#&chkND=' + (this.checked ? '1' : '0');"
					/>
					#LB_Mostrar# #Arguments.Titulo#
				</td>
			</tr>
		<cfif url.chkND NEQ "1">
			</table>
			<cfreturn>
		</cfif>
	</cfif>
    <cfinclude template="../../../Utiles/sifConcat.cfm">
	<cfquery name="lista" datasource="#session.DSN#">
		select ac.ACid, a.AnexoId, a.AnexoDes, ac.ACano, ac.ACmes, 
			ac.ACunidad,
			case 
				when ac.Ecodigo <> -1 then e.Edescripcion
				when ac.GEid	<> -1 then 'Grupo: ' #_Cat# ge.GEnombre
				else '?????'
			end as empresa,
			case 
				when ac.Ocodigo <> -1 then o.Odescripcion
				when ac.GOid	<> -1 then 'Grupo: ' #_Cat# go.GOnombre
				else 'Todas'
			end as oficina,
			case 
				when ac.Mcodigo = -1 then 'Todas (en Local)' 
				when ac.ACmLocal = 1 then m.Mnombre #_Cat# ' (en Local)' 
				else m.Mnombre  
			end as moneda,
			ac.ACfechaCalculo,
			ac.GEid, ac.Ecodigo, ac.GOid, ac.Ocodigo
			
			<cfif LvarTipoDistribucion NEQ "">
			  ,case when exists (
					select 1
					  from AnexoPermisoDef pd
					 where (pd.GAid = a.GAid or pd.AnexoId = a.AnexoId)
					   and pd.Usucodigo 	= #session.Usucodigo#
					   and pd.APdist 	= 1
				) then 1 else 0 end
				as Distribuir
			</cfif>			
		  from AnexoCalculo ac
			inner join Anexo a
			   on a.AnexoId		= ac.AnexoId
			  and a.CEcodigo	= #session.CEcodigo#
			
		
			 left outer join Empresas e
			   on e.Ecodigo		= ac.Ecodigo
			
			 left outer join Oficinas o
			   on o.Ecodigo		= ac.Ecodigo
			  and o.Ocodigo		= ac.Ocodigo
			
			 left outer join AnexoGOficina go
			   on go.GOid		= ac.GOid
			
			 left outer join AnexoGEmpresa ge
			   on ge.GEid		= ac.GEid
			
			 left outer join Monedas m
			   on m.Mcodigo		= ac.Mcodigo
		
		where 
			<cfif LvarTipoDistribucion NEQ "">
				ac.ACstatus = 'T'
			and ac.ACdistribucion = '#LvarTipoDistribucion#'
			<cfelse>
				ac.ACstatus = '#Arguments.Tipo#'
			</cfif>
		  and ac.ACfechaCalculo is not null
		    and exists (
			  		select 1
					  from AnexoGrupoCubo cubo, AnexoPermisoDef pd, AnexoEm ae
					 where cubo.GAhijo 	= a.GAid
					   and cubo.GApadre 	= #url.GAid#
					   and (pd.GAid = a.GAid or pd.AnexoId = a.AnexoId)
					   and pd.Usucodigo 	= #session.Usucodigo#
					   and pd.APcalc 	= 1
					   and ae.AnexoId 	= a.AnexoId
					   and ae.Ecodigo 	= #session.Ecodigo#
			  	)
		order by AnexoDes, a.AnexoId, ACfechaCalculo
	</cfquery>

	<cfif lista.recordcount EQ 0>
		<cfif Arguments.Tipo EQ "DN">
				<tr>
					<td colspan="9" align="center">
						<strong><cfoutput>#LB_Mensaje4#</cfoutput></strong>
					</td>
				</tr>
			</table>
		</cfif>
	<cfelse>
		<cfif Arguments.Tipo NEQ "DN">
			<table width="98%" cellpadding="0" cellspacing="0" align="center">
				<tr>
					<td colspan="9" align="center" bgcolor="##CCCCCC" style="padding:3px; ">
						<strong>#Arguments.Titulo#</strong>
					</td>
				</tr>
		</cfif>
		  <tr class="tituloListas">
			<td>&nbsp;</td>
			<td><strong>#LB_Mes#</strong></td>
			<td><strong>#LB_Periodo#</strong></td>
			<td><strong>#LB_Moneda#</strong></td>
			<td><strong>#LB_Empresa#</strong></td>
			<td><strong>#LB_Oficina#</strong></td>
			<td><strong>#LB_FechaCalculo#</strong></td>
			<td></td>
		  </tr>
		<cfset LvarAnexoIdAnt = "">
		<cfoutput query="lista">
			<cfif LvarAnexoIdAnt NEQ lista.AnexoId>
				<cfset LvarAnexoIdAnt = lista.AnexoId>
		  <tr class="<cfif lista.currentrow mod 2>listaPar<cfelse>listaNon</cfif> ">
			<td nowrap colspan="8"><strong>#LB_Anexo#: #lista.AnexoDes#</strong></td>
		  </tr>
			</cfif>
		  <tr class="<cfif lista.currentrow mod 2>listaPar<cfelse>listaNon</cfif> ">
			<td nowrap>
				<cfif listFind("F,DS,DN",Arguments.Tipo)>
					<cfif Arguments.Tipo EQ "F" OR lista.Distribuir EQ 1>
						<input type="checkbox" name="chkACid#Arguments.Tipo#" id="chkACid" value="#lista.ACid#">
					</cfif>
				</cfif>
			</td>
			<td nowrap>&nbsp;&nbsp;&nbsp;#lista.ACmes#</td>
			<td nowrap>#lista.ACano#</td>
			<td nowrap>#lista.moneda#</td>
			<td nowrap>#lista.empresa#</td>
			<td nowrap>#lista.oficina#</td>
			<td nowrap>#DateFormat(lista.ACfechaCalculo,"DD/MM/YY")# #TimeFormat(lista.ACfechaCalculo,"HH:MM")#</td>
			<td nowrap>
			<cfif LvarTipoDistribucion EQ "">
				<img src="/cfmx/sif/imagenes/Borrar01_S.gif" border="0" alt="Eliminar"
						onClick="javascript:borrar('#lista.ACid#')"  style="cursor:pointer;" 
				>
			</cfif>
			</td>
		  </tr>
		</cfoutput>
		  <tr>
			<td colspan="7">&nbsp;</td>
		  </tr>
	  <cfif Arguments.Tipo eq 'F'>
		  <tr>
			<td colspan="7" align="center">
				<input type="submit" name="btnRefrescarExcel" value="#BTN_Refrescar#" onclick="GvarRefrescar=true;">
			</td>
		  </tr>
		  <tr>
			<td colspan="7">&nbsp;</td>
		  </tr>
	  <cfelseif LvarTipoDistribucion NEQ "">
		  <tr>
			<td colspan="7" align="center">
				<cfoutput>
				<input type="submit" name="btnDistribuirMail" value="#BTN_EnviarCorreo#" onclick="GvarRefrescar=true;this.form.tipoDistribucion.value='#LvarTipoDistribucion#'">
				<cfif not isdefined("request.TipoDistribucion")>
					<input type="hidden" name="tipoDistribucion" value="">
					<cfset request.TipoDistribucion = true>
				</cfif>
				</cfoutput>
			</td>
		  </tr>
		  <tr>
			<td colspan="7">&nbsp;</td>
		  </tr>
	  </cfif>
		</table>
	</cfif>
</cffunction>


