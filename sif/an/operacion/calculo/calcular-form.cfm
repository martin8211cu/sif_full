<script language="javascript1.2" type="text/javascript">
	var GvarRefrescar = false;
	function validar(formulario){
		var error_input;
		var error_msg = '';

		if (GvarRefrescar)
			return true;
		
		if (formulario.AnexoID.value == "*") {
			error_msg += "\n - El anexo es requerido.";
			error_input = formulario.ACmes;
		}

		if (formulario.ACmes.value == "") {
			error_msg += "\n - El campo Mes es requerido.";
			error_input = formulario.ACmes;
		}
	
		if (formulario.ACano.value == "") {
			error_msg += "\n - El campo Ao es requerido.";
			error_input = formulario.ACano;
		}

		if (formulario.ACunidad.value == "") {
			error_msg += "\n - El campo Unidades es requerido.";
			error_input = formulario.ACunidad;
		}
		
		if (document.form1.opcion[1].checked){
			if (formulario.fecha.value == "") {
				error_msg += "\n - El campo Fecha es requerido.";
				error_input = formulario.fecha;
			}
			if (formulario.hora.value == "") {
				error_msg += "\n - El campo Hora es requerido.";
				error_input = formulario.hora;
			}
			else if (!validHour(formulario.hora)) {
				error_msg += "\n - El campo Hora es invlido.";
				error_input = formulario.hora;
			}
		}	
	
		// Validacion terminada
		if (error_msg.length != "") {
			alert("Se presentaron los siguientes errores:"+error_msg);
			error_input.focus();
			return false;
		}
		//sinbotones();
		return true;
	}

	function proceso(valor){
		var habilitaProgramar = valor == 'P';
		document.form1.fecha.disabled = !habilitaProgramar;
		document.form1.hora.disabled = !habilitaProgramar;
		if (valor == 'E'){
			document.form1.boton.value = 'Calcular';
		}
		else{
			document.form1.boton.value = 'Programar';
		}
	}
	
	function validHour(ctl){
		var sp = ctl.value.split(":");
		if (sp.length != 2) {
			if (ctl.value.length == 4) {
				sp = new Array(ctl.value.substring(0,2),ctl.value.substring(2,4));
			} else {
				ctl.style.color = 'red';
				return false;
			}
		}
		var hr = parseInt(sp[0], 10),
			mi = parseInt(sp[1], 10);
		if ( isNaN(hr) || hr < 0 || hr > 23 ) {
			ctl.style.color = 'red';
			return false;
		}
		if ( isNaN(mi) || mi < 0 || mi > 59 ) {
			ctl.style.color = 'red';
			return false;
		}
		if (hr < 10) hr = '0' + hr;
		if (mi < 10) mi = '0' + mi;
		var newvalue = '' + hr + ':' + mi;
		if (ctl.value != newvalue) {
			ctl.value = newvalue;
		}
		ctl.style.color = 'black';
		return true;
	}
	
	function borrar(id){
		if (confirm('Desea eliminar el registro?')){
			document.form1.ACidBorrar.value = id;
			document.form1.submit();
		}
	}
	
</script>

