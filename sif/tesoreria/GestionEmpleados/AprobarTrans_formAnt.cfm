				</tr>
				<tr>
					<td valign="top" align="right" nowrap="nowrap"><strong><cf_translate key = LB_FormaPago xmlfile = "AprobarTrans_formAnt.xml">Forma de Pago</cf_translate>: </strong></td>
				</cfoutput>		
                		
					<td valign="top" align="left"  nowrap="nowrap" colspan="6">
                    <cfif LvarCancela NEQ 1>
						<select name="FormaPago" id="FormaPago">
							<option value="-1" >(<cf_translate key = LB_SeleccionarFormaPago xmlfile = "AprobarTrans_formAnt.xml">Seleccionar Forma de Pago</cf_translate>)</option>
							<optgroup label="<cfoutput>#LB_PorTesoreria#</cfoutput>">
							<option value="0" <cfif rsForm.GEAtipoP Neq 0 and rsForm.CCHid eq 0> selected= "selected" </cfif>><cfoutput>#LB_ConChequeTEF#</cfoutput></option>
								<cfif rsCajaChica.RecordCount>
									<cfoutput query="rsCajaChica" group="CCHtipo">
										<cfif CCHtipo EQ 1>
											<optgroup label="Por Caja Chica">
