					  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<strong><cf_translate key = LB_TipoViaticos xmlfile = AprobarTrans_formAnt.xml>Tipo Viático</cf_translate></strong>:</strong>
