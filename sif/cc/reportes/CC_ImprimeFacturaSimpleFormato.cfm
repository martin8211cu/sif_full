<body style='tab-interval:35.4pt' lang="es" xml:lang="es">

<div class="Section1">
	<cfoutput>
	
		<p class="MsoNormal" align="right" style='text-align:right'>
			<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			<o:p>&nbsp;</o:p>
			</span>
		</p>
	<br />
	<br />
		<p class="MsoNormal" align="right" style='text-align:right'>
			<span style='font-size:12.0pt;mso-bidi-font-size: 12.0pt;mso-ansi-language:ES-CR; font-family:' lang="ES-CR"courier="Courier" new="New"', Courier, monospace="monospace" xml:lang="ES-CR"'>
			No. Transacción: #rsEncabezado.NoTransaccion#
			<o:p></o:p>
			</span>
		</p>
	
		<p class="MsoNormal">
			<b style='mso-bidi-font-weight:normal'>
			<span style='mso-ansi-language:ES-CR;font-size:24.0px;mso-bidi-font-size: 24.0px;font-family:' lang="ES-CR"courier="Courier" new="New"', Courier, monospace="monospace" xml:lang="ES-CR"'>
			#rsEncabezado.Empresa#
			<o:p></o:p>
			</span>
			</b>
		</p>
		<p class="MsoNormal">
			<span style='font-size:12.0pt;mso-bidi-font-size: 12.0pt;mso-ansi-language:ES-CR ; font-family:' lang="ES-CR"courier="Courier" new="New"', Courier, monospace="monospace" xml:lang="ES-CR"'>
			#rsEncabezado.Edireccion1#
			<o:p></o:p>
			</span>
		</p>
	
		<p class="MsoNormal">
			<span style='font-size:12.0pt;mso-bidi-font-size: 12.0pt;mso-ansi-language:ES-CR; font-family:' lang="ES-CR"courier="Courier" new="New"', Courier, monospace="monospace" xml:lang="ES-CR"'>
			Cédula Jurídica: #rsEncabezado.EIdentificacion#
			<o:p></o:p>
			</span>
		</p>
	
		<p class="MsoNormal" align="right" style='text-align:right'>
			<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			<o:p>&nbsp;</o:p>
			</span>
		</p>
	
		<p class="MsoNormal" align="right" style='text-align:right;border:none;mso-border-alt:solid windowtext .5pt;padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 0cm; font-family:'courier="Courier" new="New"', Courier, monospace="monospace"'>
			<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			Fecha: #DateFormat(rsEncabezado.Fecha,"DD-MM-YYYY")#
			<o:p></o:p>
			</span>
		</p>
	
		<p class="MsoNormal">
			<span style='mso-ansi-language:ES-CR; font-size:24px; color:##1E0EDC' lang="ES-CR" xml:lang="ES-CR">
				Factura
				<span class="GramE" style="color:##1E0EDC">:
					<span style='mso-spacerun:yes'>
					</span>
					<strong>#rsEncabezado.NoDocumento#</strong>
				</span>
				<o:p></o:p>
			</span>
		</p>
	
		<p class="MsoNormal" align="right" style='text-align:right'>
			<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			<o:p>&nbsp;</o:p>
			</span>
		</p>
	
		<div style='mso-element:para-border-div;border:solid windowtext 1.0pt;mso-border-alt:solid windowtext .5pt;padding:1.0pt 4.0pt 1.0pt 4.0pt; font-size:16px;font-family:'courier="Courier" new="New"', Courier, monospace="monospace"'>
	
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				Cliente:&nbsp;#rsEncabezado.NombreSocio#
				<o:p></o:p>
				</span>
			</p>
	
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;	padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				Dirección:&nbsp;#rsEncabezado.Direccion#
				<o:p></o:p>
				</span>
			</p>
	
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				<o:p>&nbsp;</o:p>
				</span>
			</p>
	
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				<o:p>&nbsp;</o:p>
				</span>
			</p>
	
		</div>
		<p class="MsoNormal"><span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR"><o:p>&nbsp;</o:p></span></p>
	</cfoutput>
</div>

<div class="SectionDetalle">
	<table width="100%" border="1" style="border:thin" cellspacing="2" cellpadding="2">
		<tr>
			<td width="15%" nowrap="nowrap" align="right"><strong>Cantidad</strong></td>
			<td width="70%"><strong>Descripci&oacute;n</strong></td>
			<td width="15%" nowrap="nowrap" align="right"><strong>Monto</strong></td>
		</tr>
		<cfoutput query="rsDetalle">
		<tr>
			<td align="right">#NumberFormat(Cantidad, ",0.00")#</td>
			<td>#Descripcion#</td>
			<td align="right">#LvarSimboloMoneda#&nbsp;#NumberFormat(Monto, ",0.00")#</td>
		</tr>
		</cfoutput>
		<cfoutput>
		<tr>
			<td colspan="3" align="center">--- &Uacute;ltima l&iacute;nea ---</td>
		</tr>
		<tr>
			<td colspan="2" align="right">Subtotal:&nbsp;</td>
			<td align="right">#LvarSimboloMoneda#&nbsp;#NumberFormat(rsEncabezado.SubTotal, ",0.00")#</td>
		</tr>
		<tr>
			<td colspan="2" align="right">Impuesto:&nbsp;</td>
			<td align="right">#LvarSimboloMoneda#&nbsp;#NumberFormat(rsEncabezado.Impuesto, ",0.00")#</td>
		</tr>
		<tr>
			<td colspan="2" align="right">Total:&nbsp;</td>
			<td align="right">#LvarSimboloMoneda#&nbsp;#NumberFormat(rsEncabezado.Total, ",0.00")#</td>
		</tr>
		<tr>
			<td colspan="3">
				*** #LvarMontoEnLetras# #rsEncabezado.Moneda# ***
			</td>
		</tr>
		</cfoutput>
	</table>

</div>
<cfoutput>
	<div style='mso-element:para-border-div;border:solid windowtext 1.0pt;mso-border-alt:solid windowtext .5pt;padding:1.0pt 4.0pt 1.0pt 4.0pt'>
		<cfif isdefined("rsEncabezado") and len(trim(rsEncabezado.OrdenCompra)) gt 0>
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;	padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				</p><span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				<o:p><div align="left" class="style1">Orden de Compra No. #rsEncabezado.OrdenCompra#</div></o:p>
				</span>
			</p>
		</cfif>
		<cfif isdefined("rsEncabezado") and len(trim(rsEncabezado.Observaciones)) GT 0>
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;	padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				</p><span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				<o:p><div align="left" class="style1"><strong>Notas:</strong></div></o:p>
				</span>
			</p>
			<p class="MsoNormal" style='border:none;mso-border-alt:solid windowtext .5pt;	padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
				</p><span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
				<o:p><div align="left" class="style1">#rsEncabezado.Observaciones#</div></o:p>
				</span>
			</p>
		</cfif>
		<p class="MsoNormal" align="right" style='text-align:right'>
			<span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			<o:p>&nbsp;</o:p>
			</span>
		</p>

		<p class="MsoNormal" style1="style1" style='border:none;mso-border-alt:solid windowtext .5pt;padding:0cm;mso-padding-alt:1.0pt 4.0pt 1.0pt 4.0pt'>
			</p><span style='mso-ansi-language:ES-CR' lang="ES-CR" xml:lang="ES-CR">
			<o:p><div align="left" class="style1">Recibo Conforme:</div></o:p>
		  </span>
		</p>
			<div class="posicion1">________________________________________</div><div class="posicion2">_______________________________________</div
			><div class="posicion3">#rsEncabezado.NombreSocio#</div><div class="posicion4">#rsEncabezado.Empresa#</div>
	</div>

	<div style='mso-element:para-border-div;border:solid windowtext 1.0pt;mso-border-alt:solid windowtext .5pt;padding:1.0pt 4.0pt 1.0pt 4.0pt'>
			  <div align="center" class="style1">Autorizado mediante resolución No.11-97 Geceta No.171 del 05-09-97 de la D.G.T.D.</div>
	</div>
	<cfif isdefined("rsAsiento") and rsAsiento.recordcount GT 0>
		<div align="center" class="style1" style='mso-element:para-border-div;border:solid windowtext 1.0pt;mso-border-alt:solid windowtext .5pt;padding:1.0pt 4.0pt 1.0pt 4.0pt'>
			<p>Informacion Contable: &nbsp;&nbsp;&nbsp;Asiento:&nbsp;&nbsp;&nbsp;#rsAsiento.Concepto#-#rsAsiento.Documento#&nbsp;&nbsp;&nbsp;&nbsp;Periodo:&nbsp;&nbsp;#rsAsiento.Mes#-#rsAsiento.Periodo#
			<br />
			Descripcion:&nbsp;&nbsp;&nbsp;#rsAsiento.Descripcion#</p>
		</div>
    </cfif>
</cfoutput>
</body>
</html>
