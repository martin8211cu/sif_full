	<queryString><![CDATA[select  rtrim(ltrim(cat.ACdescripcion)) AS ACdescripcion, rtrim(ltrim(cla.ACdescripcion)) as clasedescripcion, 
b.CFid, b.TAid, sum(round(TAmontolocadq,2)) as AFSvalrev
, rtrim(cf.CFcodigo) as CFcodigo
, rtrim(ltrim(cf.CFdescripcion)) as CFdescripcion
, c.Edescripcion as Edescripcion
, cla.ACcodigodesc, cat.ACcodigodesc as categoria
from Activos a inner join TransaccionesActivos b on b.Ecodigo = a.Ecodigo 
  and b.Aid = a.Aid
  and (b.CFid = $P{Centro} or $P{Centro} = 0)
 and b.TAperiodo = $P{Periodo}
 and b.TAmes =  $P{Mes}
 and b.IDtrans = 3
inner join ACategoria cat on cat.Ecodigo = a.Ecodigo  and cat.ACcodigo = a.ACcodigo
   and (cat.ACcodigo = $P{Categoria} or $P{Categoria} = 0)
inner join AClasificacion cla on cla.Ecodigo = a.Ecodigo  and cla.ACcodigo = a.ACcodigo and cla.ACid = a.ACid
    and (cla.ACcodigo = $P{Categoria} or $P{Categoria} = 0)
    and (cla.ACid = $P{Clase} or $P{Clase} = 0)
,Empresas c
,CFuncional cf
where a.Ecodigo = $P{Ecodigo}
  and (b.CFid = $P{Centro} or $P{Centro} = 0)
  and a.Ecodigo = c.Ecodigo
  and b.CFid = cf.CFid
  and b.IDtrans = 3
group by cat.ACdescripcion, cla.ACdescripcion, b.CFid, b.TAid
, rtrim(cf.CFcodigo), cf.CFdescripcion , c.Edescripcion, cla.ACcodigodesc, cat.ACcodigodesc]]></queryString>
