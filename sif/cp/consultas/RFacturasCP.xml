	<queryString><![CDATA[select 
	b.Ecodigo, 
	e.Edescripcion,
	b.Ecodigo, 
	b.CPTcodigo, 
	c.CPTdescripcion, 
	case when c.CPTtipo = 'D' then 'Débito' when c.CPTtipo = 'C' then 'Crédito' end as tipo, 
	b.Ddocumento, 
	convert(varchar,b.Dfecha,103) as Dfecha, 
	b.BMtref, 
	BMdocref,
	o.Odescripcion, 
	b.SNcodigo, 
	s.SNnombre, 
	b.Mcodigo, 
	m.Mnombre, 
	b.Dtotal,
	convert(varchar,getdate(), 103) + ' ' + convert(varchar,getdate(),108) as fecha_hora,
	b.Dtotal*Dtipocambio as Dtotalloc, 
	Dtipocambio,
	b.SNcodigo, 
	s.SNnumero,
	b.Rcodigo, 
	coalesce(r.Rporcentaje, 0) as Rporcentaje

from BMovimientosCxP b, CPTransacciones c, Oficinas o, SNegocios s, Monedas m, Empresas e, Retenciones r

where b.Ecodigo = $P{Ecodigo}

  and b.Dfecha >= isnull(convert(datetime,$P{BMfecha},103),b.Dfecha)
  and (upper(b.Ddocumento) like upper($P{Ddocumento}) or upper(BMdocref) like upper($P{Ddocumento})  or $P{Ddocumento} like 'Todos')
  and (b.SNcodigo = $P{SNcodigo} or $P{SNcodigo} = -1)
  and (b.CPTcodigo = $P{CPTcodigo} or $P{CPTcodigo} = '-1')

  and  c.CPTpago = 0
   and b.CPTcodigo = b.CPTRcodigo
  and b.Ddocumento = b.DRdocumento

  and b.Ecodigo = c.Ecodigo
  and b.CPTcodigo = c.CPTcodigo
  and b.Ecodigo = o.Ecodigo
  and b.Ocodigo = o.Ocodigo
  and b.Ecodigo = s.Ecodigo
  and b.SNcodigo = s.SNcodigo
  and b.Ecodigo = m.Ecodigo
  and b.Mcodigo = m.Mcodigo
  and b.Ecodigo = e.Ecodigo

  and b.Rcodigo*=r.Rcodigo
  and b.Ecodigo*=r.Ecodigo

order by b.SNcodigo, b.Mcodigo, b.CPTcodigo, b.Dfecha desc]]></queryString>
