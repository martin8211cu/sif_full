	var popUpWin=0;
	function popUpWindow(URLStr, left, top, width, height){
	  if(popUpWin) {
		if(!popUpWin.closed) popUpWin.close();
	  }
	  popUpWin = open(URLStr, 'popUpWin', 'toolbar=no,location=no,directories=no,status=no,menub ar=no,scrollbar=no,resizable=no,copyhistory=yes,width='+width+',height='+height+',left='+left+', top='+top+',screenX='+left+',screenY='+top+'');
	}

	function doConlis( id, desc, mcodigo, mnombre, tipocambio, tipo, monto, pmoneda ) {
		var CBid = "";
		if ( tipo == 'o' ){
			CBid   = document.transferencia.CBiddest.value
		}
		else{
			CBid = document.transferencia.CBidori.value
		}
		
		moneda = document.transferencia[pmoneda].value
		
		popUpWindow("/cfmx/sif/mb/operacion/TConlisCuentas.cfm?form=transferencia&id=" + id + "&desc=" + desc + "&mcodigo=" + mcodigo + '&tipo=' + tipocambio 
		                                                        +"&mnombre=" + mnombre + "&oTipo=" + tipo + "&CBid=" + CBid + "&moneda=" 
																+ moneda + "&monto=" + monto + "&eMcodigo=" + document.transferencia.eMcodigo.value
																+ "&fecha=" + document.transferencia.ETfecha.value, 250,200,650,350);
	}
	// ===========================================================================================

function qf(Obj)
{
		var VALOR=""
		var HILERA=""
		var CARACTER=""
		if(Obj.name)
		  VALOR=Obj.value
		else
		  VALOR=Obj
		
		for (var i=0; i<VALOR.length; i++) {	
		
			CARACTER =VALOR.substring(i,i+1);
			if (CARACTER=="," || CARACTER==" ") {
				CARACTER=""; //CAMBIA EL CARACTER POR BLANCO
			}  
			HILERA+=CARACTER;
		}
		return HILERA
}
<cfoutput>
function MM_validateForm() { //v4.0
	var boton = document.transferencia.botonSel.value
	var i,p,q,nm,test,num,min,max,errors='',args=MM_validateForm.arguments;

	if ( ( boton != 'btnBorrarE' ) && ( boton != 'btnBorrarD' )  && ( boton != 'btnAplicar' ) && (boton != 'btnNuevoD') ) {
		for (i=0; i<(args.length-2); i+=3) { 
			test=args[i+2]; 
			val=MM_findObj(args[i]);
			if (val) { 
				if (val.alt!="") 
					nm=val.alt; 
				else 
					nm=val.name; 
				
				if ((val=val.value)!="") {
					if (test.indexOf('isEmail')!=-1) { 
						p=val.indexOf('@');
						if (p<1 || p==(val.length-1)) 
							errors+='- '+nm+' #MSG_Correo#.\n';
					} 
					else if (test!='R') { 
						num = parseFloat(val);
						if (isNaN(val)) 
							errors+='- '+nm+' #MSG_Numerico#.\n';
					
						if (test.indexOf('inRange') != -1) { 
							p=test.indexOf(':');
							min=test.substring(8,p); 
							max=test.substring(p+1);
							if (num<min || max<num) 
								errors+='- '+nm+' #MSG_NumeroEntre# '+min+' #MSG_And# '+max+'.\n';
						} 
					} 
				} 
				else if (test.charAt(0) == 'R') 
					errors += '- '+ '#MSG_Campo# '+nm+' #MSG_Requerido#.\n'; 
			}
		} 
		
		if ( ( boton == 'btnAgregarD' ) || ( boton == 'btnCambiarD' ) ) {
			
			if ( parseFloat(document.transferencia.DTmontoori.value) == 0 ){
				errors += '- '+ '#MSG_Origen#.\n'; 
			}

			if ( parseFloat(document.transferencia.DTmontodest.value) == 0 ){
				errors += '- '+ '#MSG_Destino#.\n'; 
			}
			
			if ( parseFloat(document.transferencia.DTtipocambio.value) == 0 ){
				errors += '- '+ '#MSG_TipoCambio#.\n'; 
			}

			if (!errors){
				var tc  = new Number(qf(document.transferencia.DTtipocambio));
				var mo  = new Number(qf(document.transferencia.DTmontoori));
				var md  = new Number(qf(document.transferencia.DTmontodest));
				var mc  = new Number(qf(document.transferencia.DTmontocomori));
				
				var t_mo  = tc * mo;
				var t_mc  = tc * mc;
				var t_tcf = md/mo;
	
				document.transferencia.DTmontolocal.value  = t_mo;
				document.transferencia.DTmontocomloc.value = t_mc;
				document.transferencia.DTtipocambiof.value = t_tcf;
			}	
		}

		if ( ( ( boton == 'btnAgregarD' ) || ( boton == 'btnCambiarD' ) ) && errors ) {
			validar_monto(); 
			validar_tc(); 
		}

		if (errors) {
			alert('#MSG_Errores#:\n\n'+errors);
		}	
		document.MM_returnValue = (errors == '');
	}
	else{
		if ( boton == 'btnBorrarD'){
			if ( confirm('#MSG_EliminaDet#') ){
				document.MM_returnValue = true;
			}
			else{
				document.MM_returnValue = false;
			}
		}

		if ( boton == 'btnBorrarE'){
			if ( confirm('#MSG_EliminaTran#') ){
				document.MM_returnValue = true;
			}
			else{
				document.MM_returnValue = false;
			}
		}

		if ( boton == 'btnAplicar'){
			if ( confirm('#MSG_Aplica#') ){
				document.MM_returnValue = true;
			}
			else{
				document.MM_returnValue = false;
			}
		}

		if ( boton == 'btnNuevoD'){
			document.MM_returnValue = true;
		}
	}	
}
</cfoutput>
	// =====================================================================
	// 						VALIDACIONES ESPECIALES (CAMBIO)
	// =====================================================================	

		function validar_monto(){
			if ( document.transferencia.dMcodigo.value == document.transferencia.oMcodigo.value &&
				 document.transferencia.dMcodigo.value != "" && 
			     document.transferencia.oMcodigo.value != ""
			   ){
				document.transferencia.DTmontodest.disabled = true;
			}
			return;		
		}
		
		function validar_tc(){		
			if ( document.transferencia.eMcodigo.value == document.transferencia.oMcodigo.value ){
				document.transferencia.DTtipocambio.disabled = true;
			}	
			return;
		}

		function validar_md(){		
			if ( document.transferencia.eMcodigo.value == document.transferencia.dMcodigo.value ){
				document.transferencia.DTmontodest.disabled = true;
			}	
			return;
		}

		function validar(){
			// tipo cambio 4 digitos
			fm(document.transferencia.DTtipocambio, 4);
	
			// si las monedas son iguales, el monto destino se desactiva
			validar_monto();
			
			// si la moneda de la empresa es igual a la moneda de la cuenta origen, se desactiva el campo de tipo de cambio
			validar_tc();
			
			// si la moneda de la empresa es igual a la moneda de la cuenta destino, se desactiva el campo de monto dstino
			validar_md();
			
		}
		
		function activar(){
			document.transferencia.DTtipocambio.disabled = false;
			document.transferencia.DTmontodest.disabled  = false;
		}
		
		function valida_comision(){
			var montoori  = new Number(qf(document.transferencia.DTmontoori))
			var montodest = new Number(qf(document.transferencia.DTmontocomori))

			if ( document.transferencia.DTmontoori.value != "" && 
			     document.transferencia.DTmontocomori.value != "" &&
 				 montoori < montodest
			   )
			{
				alert('<cfoutput>#MSG_ErrorComision#</cfoutput>')
				document.transferencia.DTmontocomori.value = "0.00";
				document.transferencia.DTmontocomori.focus();
				return;
			
			}
		}
		
		function sugiere_monto( valor ){
			if ( ( document.transferencia.dMcodigo.value == document.transferencia.oMcodigo.value) && 
				 !( document.transferencia.dMcodigo.value == document.transferencia.eMcodigo.value)	&&
			       (document.transferencia.CBDidori.value != "" )
			   ){
				document.transferencia.DTmontodest.value = valor;
			}
			// Limpia el campo de monto destino cuando las monedas son diferentes y solo en dmodo = ALTA,
			// en CAMBIO no pues no se captura nada de los combos y no hay eventos
			else{
				if ( ( document.transferencia.dMcodigo.value == document.transferencia.eMcodigo.value) && 
						( document.transferencia.DTmontoori.value != "" ) && 
						( document.transferencia.DTtipocambio.value != "")
				   ){
						document.transferencia.DTmontodest.value = (new Number(qf(document.transferencia.DTmontoori.value))) * (new Number(qf(document.transferencia.DTtipocambio.value)));
						fm(document.transferencia.DTmontodest, 2);
						document.transferencia.DTmontodest.disabled = true;
				  }
				  else{
					<cfif dmodo eq 'ALTA' >
						document.transferencia.DTmontodest.value = '0.00';
					</cfif>
				  }	
			}
			
			return;		
		}
		
		function limpiarcampos(){
			<cfif dmodo eq 'ALTA'>
				document.transferencia.DTmontodest.disabled  = false;
				document.transferencia.DTtipocambio.disabled = false;				
			<cfelse>
				fm(document.transferencia.DTtipocambio, 4)
			</cfif>
		}
		
		function total() {
			document.transferencia.Tdebitar.value = (new Number(qf(document.transferencia.DTmontoori.value))) + (new Number(qf(document.transferencia.DTmontocomori.value)))
			fm(document.transferencia.Tdebitar, 2);
		}
		
		// VALIDACION DE FECHAS
//==========================================================================		
		function ESFECHA(FECHA) 
		{ 
		if (FECHA.length != 10) return false; 
		dia = FECHA.substring(0, 2)
		slash1 = FECHA.substring(2, 3)
		mes = FECHA.substring(3, 5)
		slash2 = FECHA.substring(5, 6)
		ano = FECHA.substring(6, 10)
		if(!Number(mes)) return false;
		if(!Number(dia)) return false;
		if(!Number(ano)) return false; 
		
		if (mes<1 || mes>12) return false; 
		if(slash1=='-') slash1='/'
		if (slash1!='/') return false; 
		if (dia<1 || dia>31) return false; 
		if(slash2=='-') slash2='/'
		if (slash2!='/') return false; 
		if (ano<0 || ano>3000) return false; 
		if (mes==4 || mes==6 || mes==9 || mes==11)
			{if (dia==31) return false;} 
		if (mes==2)
			{
			var bisiesto=parseInt(ano/4)
			if (isNaN(bisiesto)) 
				{
				return false; 
				}
			if (dia>29) return false; 
			if (dia==29 && ((ano/4)!=parseInt(ano/4))) return false; 
			}
		return true;
		}
//Verifica si un valor dado en formato dd/mm/yyyy  corresponde a una fecha valida

		
	function fmd(OBJ){
	// RESULTADO
	// Formatea una fecha
		var  DIA =''
		var MES  = ''
		var ANO  = ''
		
		var FECHA = OBJ.value
		if(FECHA.length==0){
			return true;
		}	
		
		if(ESFECHA(FECHA)){
			return true;
		}	
		
		if(FECHA.length!=8){
		 	alert ('<cfoutput>#MSG_FechaIncorrecta#</cfoutput>'); OBJ.focus(); 
			return false;
		}

		DIA = FECHA.substring(0,2)
		MES = FECHA.substring(2,4)
		ANO = FECHA.substring(4,8)
		OBJ.value = DIA+'/'+MES+'/'+ANO

		if(!ESFECHA(OBJ.value)){
			alert ('<cfoutput>#MSG_FechaIncorrecta#</cfoutput>'); OBJ.focus(); 
			return false;
		}
		return true
	}
	
	function tcambio(obj){
		if ( fmd(obj) ){
			<cfif modo neq 'ALTA'>
				if (obj.value != ""){
					document.all['ifTipoCambio'].src="/cfmx/sif/mb/operacion/tipocambio.cfm?eMcodigo=" + document.transferencia.eMcodigo.value +
																					  "&oMcodigo=" + document.transferencia.oMcodigo.value +
																					  "&fecha=" + obj.value;
				}
			</cfif>
		}
		return;	
	}
// ============================================================================		
		
</script>

