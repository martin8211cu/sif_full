<!--- Begin UDF's Definition --->
<!---  Recupera el tipo de transaccion --->
<cffunction name="transaccion" access="public" returntype="query">
	<cfargument name="pcodigo" type="numeric" required="true" default="0">
	<cfquery name="rsTransaccion" datasource="#session.DSN#" >
		select 
		<cf_dbfunction name="to_number" args="a.Pvalor"> as Pvalor, 
		b.BTdescripcion		
		from Parametros a, BTransacciones b 		
		where a.Ecodigo=<cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
		  and a.Pcodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#pcodigo#">
		  and a.Mcodigo='MB'
		  and a.Ecodigo=b.Ecodigo
		  and b.BTid=<cf_dbfunction name="to_number" args="a.Pvalor">
	</cfquery>
	<cfreturn #rsTransaccion#>
</cffunction>

<cffunction name="cuenta_banco" access="public" returntype="query">
	<cfargument name="cbid" type="numeric" required="true" default="0">
	<cfquery name="rsCuenta" datasource="#session.DSN#" >
		select a.CBdescripcion, a.Mcodigo, b.Mnombre
		from CuentasBancos a 
			inner join Monedas b
				on a.Mcodigo=b.Mcodigo
		where  a.Ecodigo=<cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
        	and a.CBesTCE = <cfqueryparam value="0" cfsqltype="cf_sql_bit">
			and a.CBid=<cfqueryparam cfsqltype="cf_sql_numeric"    value="#cbid#">		
	</cfquery>
	<cfreturn #rsCuenta#>
</cffunction>

