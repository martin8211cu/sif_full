	<parameter name="SNcodigo" class="java.math.BigDecimal">
	</parameter>
	<parameter name="Mcodigo" class="java.math.BigDecimal">
	</parameter>
	<queryString><![CDATA[select 	a.Ecodigo, 
		d.Edescripcion,
		a.SNcodigo,
		e.SNnumero,
		e.SNnombre,
		a.Ddocumento, 
		a.Dfecha, 
		a.Dvencimiento, 
		b.DDcantidad, 
		a.Dtotal as Dtotallinea,
                                           b.DDpreciou, 
		b.DDcodartcon, 
		c.Acodigo, 
		c.Adescripcion, 
		c.Ucodigo,
		( select sum(Dtotal)
		  from Documentos a
		  where a.Ecodigo=$P{Ecodigo}
    		and a.SNcodigo=$P{SNcodigo}) as DTotal

from Documentos a

inner join DDocumentos b
on a.Ecodigo=b.Ecodigo
and a.CCTcodigo=b.CCTcodigo
and a.Ddocumento=b.Ddocumento

inner join Articulos c
on b.Ecodigo=c.Ecodigo
and b.DDcodartcon = c.Aid

inner join Empresas d
on a.Ecodigo=d.Ecodigo

inner join SNegocios e
on a.SNcodigo=e.SNcodigo
and a.Ecodigo=e.Ecodigo

where a.Ecodigo=$P{Ecodigo}
    and a.SNcodigo=$P{SNcodigo}
    and a.Mcodigo=$P{Mcodigo}


]]></queryString>
