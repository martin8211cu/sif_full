	<queryString><![CDATA[	select 	convert(varchar,a.DEid) as DEid, 
			convert(varchar,a.RCNid) as RCNid,
			b.DEidentificacion, 
			b.DEapellido1 + ' ' + b.DEapellido2 + ' ' + b.DEnombre as Nombre, 
			SEsalariobruto, 
			SEincidencias, 
			SErenta, 
			SEcargasempleado, 
			SEdeducciones, 
			SEliquido
	from SalarioEmpleado a, DatosEmpleado b, RCalculoNomina c
	where c.Ecodigo = 1
			and c.Tcodigo = 'GEN'
			and a.RCNid =  1107
			and a.DEid = b.DEid
			and a.RCNid = c.RCNid
order by b.DEidentificacion, b.DEapellido1, b.DEapellido2, b.DEnombre
]]></queryString>
