<cffunction name="generarFila" returntype="any" description="Pinta de acuerdo a las condiciones">
	<cfoutput>
		<cfif LvarIncluirOficina>
			<cfif LvarOficodigoControl NEQ rsReporte.Oficodigo>
				<cfif LvarOficodigoControl NEQ "-1">
					<tr>
					<td nowrap><strong>#MSG_TotalesOficina#:</strong></td>
					<td nowrap>&nbsp;</td>
					<td nowrap>&nbsp;</td>
					<td nowrap align="right" class="Datos" x:num><strong>#numberformat(Total_Debitos, ",9.00")#</strong></td>
					<td nowrap align="right" class="Datos" x:num><strong>#numberformat(Total_Creditos, ",9.00")#</strong></td>
					<td nowrap align="right" class="Datos" x:num><strong>#numberformat(Total_Debitos - Total_Creditos, ",9.00")#</strong></td>
					<td nowrap align="right" class="Datos" x:num><strong>#numberformat(Total_Saldo, ",9.00")#</strong></td>
					</tr>
					<tr>
						<td colspan="7">&nbsp;</td>
					</tr>
					<cfset Total_Debitos = 0>
					<cfset Total_Creditos = 0>
					<cfset Total_Saldo = 0>
				</cfif>
				<cfset LvarOficodigoControl = rsReporte.Oficodigo>
				<tr>
				<td colspan="7"><strong>#MSG_Oficina#:#rsReporte.Oficodigo# #rsReporte.Odescripcion#</strong></td>
				</tr>
			</cfif>
		</cfif>
<!---		<cfdump var="#len(rsReporte.formato)#">
		<cfdump var="#len(rsReporte.mayor)#">--->
<!---		<tr <cfif len(rsReporte.formato) LT 5 and (rsReporte.mayor EQ rsReporte.formato)>class="corte"</cfif>>--->
		<tr <cfif len(trim(rsReporte.formato)) LT 5 and (trim(rsReporte.mayor) EQ trim(rsReporte.formato))>class="corte"</cfif>>
			<td nowrap >&nbsp;
				<cfif len(rsReporte.formato) GT 5>
					&nbsp;&nbsp;&nbsp;
				</cfif>
				<cfif isdefined("url.LvarSumasSaldos")>
					#mid(rsReporte.formato,2,(len(rsReporte.formato) - 1))#
				<cfelse>
					#rsReporte.formato#
				</cfif>
			</td>
			<td nowrap >#rsReporte.descrip#</td>
			<td nowrap align="right" class="Datos" x:num>#numberformat(rsReporte.saldoini, ",9.00")#</td>
			<td nowrap align="right" class="Datos" x:num>#numberformat(rsReporte.debitos, ",9.00")#</td>
			<td nowrap align="right" class="Datos" x:num>#numberformat(rsReporte.creditos, ",9.00")#</td>
			<td nowrap align="right" class="Datos" x:num>#numberformat(rsReporte.movmes, ",9.00")#</td>
			<td nowrap align="right" class="Datos" x:num>#numberformat(rsReporte.saldofin, ",9.00")#</td>
		</tr>
    </cfoutput>
</cffunction>

