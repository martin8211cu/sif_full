		mescierre="#url.CHKMesCierre#"
		>	</cfinvoke>			     
    
<cfcatch type="any">
	<cfinclude template="../../errorPages/BDerror.cfm">
</cfcatch>
</cftry> 

<cfif not LvarIncluirOficina>
	<cf_dbfunction name="to_char" args="getdate()" returnvariable="LvarFecha">
	<cfquery name="rsReporte" datasource="#session.DSN#"> 
		select
			min(a.Ecodigo) as Ecodigo,
			min(a.Ccuenta) as Ccuenta,
			min(#url.periodo#) as Periodo,
			min(#url.mes#) as Mes,
			min(#myOcodigo#) as Oficina,
			'#moneda#' as moneda,
			a.corte as corte,
			a.nivel as nivel, 
			a.tipo as tipo, 
			a.ntipo as ntipo, 
			a.mayor as mayor, 
			a.descrip as descrip, 
			a.formato as formato,
			sum(a.saldoini) as saldoini, 
			sum(a.saldofin) as saldofin, 
			sum(a.debitos) as debitos, 
			sum(a.creditos) as creditos, 
			sum(a.movmes) as movmes,
			#LvarMcodigo# as Mcodigo, 
			min(a.Edescripcion) as Edescripcion,
			a.totdebitos,
			a.totcreditos,
			a.totmovmes, 
			a.totsaldofin,
			a.rango as rango,
            b.Cmovimiento
		from DCGRBalanceComprobacion a
        		inner join CContables b on
                	a.Ccuenta = b.Ccuenta and
                    a.Ecodigo = b.Ecodigo
		where CGRBCid = #rs_Res# 
        <cfif session.Conta.balances.nivelSeleccionado and url.formato NEQ "HTML">
        	and (b.Cmovimiento = 'S' or a.nivel = (#url.NIVEL# - 1))
      	</cfif>
		group by
				a.corte,
				a.nivel, 
				a.tipo, 
				a.ntipo, 
				a.mayor, 
				a.descrip, 
				a.formato,
				<!---Edescripcion, --->
				a.rango,
				a.totdebitos,
				a.totcreditos,
				a.totmovmes, 
				a.totsaldofin,
                b.Cmovimiento
		order by 
        <!---case when a.tipo = 'A' then 1
                      when a.tipo = 'P' then 2
                      when a.tipo = 'C' then 3
                      when a.tipo = 'I' then 4
                      when a.tipo = 'G' then 5
                      when a.tipo = 'O' then 6
                   end, --->           
                 a.mayor, a.formato
	</cfquery>
<cfelse>
	<cfquery name="rsReporte" datasource="#session.DSN#">
		select
			a.Ecodigo as Ecodigo,
			a.Ccuenta as Ccuenta,
			#url.periodo# as Periodo,
			#url.mes# as Mes,
			#myOcodigo# as Oficina,
			'#moneda#' as moneda,
	 		a.corte as corte,
			a.nivel as nivel, 
			a.tipo as tipo, 
			a.ntipo as ntipo, 
			a.mayor as mayor, 
			a.descrip as descrip, 
			a.formato as formato,
			a.saldoini as saldoini, 
			a.saldofin as saldofin, 
			a.debitos as debitos, 
			a.creditos as creditos, 
			a.movmes as movmes,
			#LvarMcodigo# as Mcodigo, 
			a.Edescripcion as Edescripcion, 
			a.totdebitos as totdebitos, 
			a.totcreditos as totcreditos,
			a.totmovmes as totmovmes, 
			a.totsaldofin as totsaldofin,
			a.rango as rango,
			o.Oficodigo as Oficodigo,
			o.Odescripcion as Odescripcion,
            b.Cmovimiento
		from DCGRBalanceComprobacion a
			inner join Oficinas o
				on o.Ecodigo = a.Ecodigo
			   and o.Ocodigo = a.Ocodigo
			inner join CContables b on
                a.Ccuenta = b.Ccuenta and
                a.Ecodigo = b.Ecodigo
		where CGRBCid = #rs_Res#
		<cfif session.Conta.balances.nivelSeleccionado and url.formato NEQ "HTML">
        	and (b.Cmovimiento = 'S' or a.nivel = (#url.NIVEL# - 1))
      	</cfif>
		order by     <!---case when  tipo = 'A' then 1
                      when tipo = 'P' then 2
                      when tipo = 'C' then 3
                      when tipo = 'I' then 4
                      when tipo = 'G' then 5
                      when tipo = 'O' then 6
                   end, --->
        o.Oficodigo, a.mayor, a.formato
	</cfquery>
</cfif>

