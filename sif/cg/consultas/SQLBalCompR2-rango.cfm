		Ocodigo="#myOcodigo#"
		myGEid="#myGEid#"
		myGOid="#myGOid#"
		ceros="#LvarMostarCeros#"
		mescierre="#url.CHKMesCierre#"
		>
	</cfinvoke>			

<cfcatch type="any">
