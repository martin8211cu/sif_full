	<parameter name="Ecodigo" class="java.math.BigDecimal">
	</parameter>
	<parameter name="Dreferencia" class="java.math.BigDecimal">
	</parameter>
	<queryString><![CDATA[select a.Ecodigo, 
	   e.Edescripcion,
	   a.SNcodigo,
	   f.SNnumero,
	   f.SNnombre,
	   a.Ddocumento, 
	   a.EDAfechaglobal, 
	   a.EDAfechavenc, 
	   b.DDcantidad, 
       b.DDpreciou, 
       b.DDtotal, 
	   b.DDcodartcon, 
	   case DDtipo when 'A' then c.Acodigo when 'S' then d.Ccodigo end as Acodigo, 
	   case DDtipo when 'A' then c.Adescripcion when 'S' then d.Cdescripcion end as Adescripcion, 
	   c.Ucodigo,
       a.EDAtotalglobal,
	   a.EDAtotaldoc
from EDocumentosAgrupados a

inner join DDocumentosAgrupados b
on a.EDAid=b.EDAid
   and a.Ecodigo=b.Ecodigo

left outer join Articulos c
on b.DDcodartcon=c.Aid
and b.Ecodigo=c.Ecodigo

left outer join Conceptos d
on b.DDcodartcon=d.Cid
and b.Ecodigo=d.Ecodigo

inner join Empresas e
on a.Ecodigo=e.Ecodigo

inner join SNegocios f
on a.SNcodigo=f.SNcodigo
and a.Ecodigo=f.Ecodigo

where a.Ecodigo=$P{Ecodigo}
and a.Dreferencia=$P{Dreferencia}

]]></queryString>
