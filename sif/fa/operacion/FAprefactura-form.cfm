		<!---Verificar la logica de Impresion de Cotizaciones ABG--->
		function funcImprimir(){
	<!---		var width = 700;
			var height = 500;
			var top = (screen.height - height) / 2;
			var left = (screen.width - width) / 2;--->
			if (confirm('�Desea Imprimir la Cotizaci&oacute;n?')) {
				document.form1.action='FAprefactura-Imprime.cfm';
				document.form1.submit();

		<!---		<cfoutput>
				var params = "?IDpreFactura=#rsForm.IDpreFactura#&ruta="+escape('#rsArchivoImp.cfmCotizacion#');
				var nuevo = window.open('reporte_documento.cfm'+params,'Cotizaciones','menu=no,scrollbars=no,top='+top+',left='+left+',width='+width+',height='+height);
