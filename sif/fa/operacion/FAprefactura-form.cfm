function DisplayModal()
    {
        document.getElementById("overlay").style.height = getDocHeight() + 'px';
        document.getElementById("overlay").style.width = getDocWidth() + 'px';
        document.getElementById("overlay").className = "OverlayEffect";
        document.getElementById("modalMsg").className = "ShowModal";
        return false;
    }
function RemoveModal()
{
    document.getElementById("modalMsg").className = "HideModal";
    document.getElementById("overlay").className = "HideModal";
    return false;
}
function getDocHeight() {
    var D = document;
    return Math.max(
        D.body.scrollHeight, D.documentElement.scrollHeight,
        D.body.offsetHeight, D.documentElement.offsetHeight,
        D.body.clientHeight, D.documentElement.clientHeight
    );
}
	function getDocWidth() {
    var D = document;
    return Math.max(
        D.body.scrollWidth, D.documentElement.scrollWidth,
        D.body.offsetWidth, D.documentElement.offsetWidth,
        D.body.clientWidth, D.documentElement.clientWidth
    );
	}
