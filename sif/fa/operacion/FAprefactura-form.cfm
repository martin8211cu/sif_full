	function validacionForm(){
		var lvarReturn = true;
		var Oficodigo = document.getElementById('Oficodigo').value;
		var PFdocumento = document.getElementById('PFdocumento').value;
		var SNnumero = document.getElementById('SNnumero').value;
		var id_direccion = document.getElementById('id_direccion').value;
		var ExisteExport = document.getElementById('Expcodigo');



		if(PFdocumento.trim() == ""){
			alert('Favor de ingresar la Pre-Factura');
			lvarReturn = false;
		} else if(SNnumero.trim() == ""){
			alert('Favor de seleccionar un cliente');
			lvarReturn = false;
		} else if(id_direccion.trim() == ""){
			alert('Favor de seleccionar una direccion');
			lvarReturn = false;
		} else if(Oficodigo.trim() == ""){
			alert('Favor de seleccionar una Oficina');
			lvarReturn = false;
		} else if(ExisteExport !== null){
			var id_exportacion = document.getElementById('Expcodigo').value;
			if (id_exportacion.trim() == ""){
				 alert('Favor de seleccionar el Tipo de Exportación');
				 lvarReturn = false;
			}
		}

		if(lvarReturn== true){
			validaMon();
		}
		
		return lvarReturn;
	}
