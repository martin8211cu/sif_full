    Sub tabDEtoPD(ByVal pTab As String)
        Dim t As Integer
        Dim p As Integer
        Dim LvarTab As PdPDM.Table

        LvarTab = fnbuscarTablaC(GvarTabsDE, pTab)
        'MsgBox(LvarTab.Code)
        LvarTab.CreateReplica(GvarTN)
    End Sub

    Sub colDEtoPD(ByVal pTab As String, ByVal pCol As String)
        Dim t As Integer
        Dim p As Integer
        Dim LvarTab1 As PdPDM.Table
        Dim LvarTab2 As PdPDM.Table
        Dim LvarCol1 As PdPDM.Column

        LvarTab1 = fnbuscarTablaC(GvarTabsDE, pTab)
        LvarTab2 = fnbuscarTablaC(GvarTabsPD, pTab)
        LvarCol1 = fnBuscarCol(LvarTab1, pCol)
        'MsgBox(LvarTab.Code)
        LvarCol1.CreateReplica(LvarTab2, pTab)
        LvarTab2.CreateShortcut(GvarTN)
    End Sub

    Function fnBuscarCol(ByVal ptab As PdPDM.Table, ByVal pcol As String) As PdPDM.Column
        Dim LvarCol As PdPDM.Column

        For Each LvarCol In ptab.Columns
            If LvarCol.Code = pcol Then
                fnBuscarCol = LvarCol
                Exit Function
            End If
        Next
    End Function

    Function fnBuscarKey(ByVal ptab As PdPDM.Table, ByVal pcols As String) As PdPDM.Key
        Dim LvarKey As PdPDM.Key
        Dim LvarCol As PdPDM.Column
        Dim LvarCols As String

        For Each LvarKey In ptab.Keys
            LvarCols = ""
            For Each LvarCol In LvarKey.Columns
                LvarCols = LvarCols & "," & LvarCol.Code
            Next
            If LvarCols = "," & pcols Then
                fnBuscarKey = LvarKey
                Exit Function
            End If
        Next
        fnBuscarKey = Nothing
    End Function

    Function fnBuscarTabla(ByVal modelo As PdPDM.Model, ByVal tabla As String)
        Dim t As Integer
        Dim p As Integer
        Dim LvarTab As PdPDM.Table

        LvarTab = Nothing
        For t = 1 To modelo.Tables().Count
            If Not modelo.Tables().Item(t - 1).IsShortcut Then
                If CType(modelo.Tables().Item(t - 1), PdPDM.Table).Code = tabla Then
                    LvarTab = CType(modelo.Tables().Item(t - 1), PdPDM.Table)
                    Exit For
                End If
            End If
        Next t

        For p = 1 To modelo.Packages().Count
            If Not LvarTab Is Nothing Then Exit For
            For t = 1 To CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Count
                If Not CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Item(t - 1).IsShortcut Then
                    If CType(CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Item(t - 1), PdPDM.Table).Code = tabla Then
                        LvarTab = CType(CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Item(t - 1), PdPDM.Table)
                        Exit For
                    End If
                End If
            Next t
        Next p
        fnBuscarTabla = LvarTab
    End Function

    Function fnBuscarTablaC(ByVal pTabs As Collection, ByVal tabla As String) As PdPDM.Table
        fnBuscarTablaC = pTabs(tabla)
    End Function

    Function fnCargarTablas(ByVal modelo As PdPDM.Model) As Collection
        Dim t As Integer
        Dim p As Integer
        Dim LvarTab As PdPDM.Table
        Dim LvarTabs As New Collection

        LvarTab = Nothing
        For t = 1 To modelo.Tables().Count
            If Not modelo.Tables().Item(t - 1).IsShortcut Then
                LvarTab = CType(modelo.Tables().Item(t - 1), PdPDM.Table)
                LvarTabs.Add(LvarTab, LvarTab.Code)
            End If
        Next t

        For p = 1 To modelo.Packages().Count
            For t = 1 To CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Count
                If Not CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Item(t - 1).IsShortcut Then
                    LvarTab = CType(CType(modelo.Packages().Item(p - 1), PdPDM.Package).Tables().Item(t - 1), PdPDM.Table)
                    LvarTabs.Add(LvarTab, LvarTab.Code)
                End If
            Next t
        Next p
        fnCargarTablas = LvarTabs
    End Function
End Module

