    Function fnCreateTable(ByVal pTab As String) As String
        Dim LvarTab As PdPDM.Table
        Dim LvarSQL As String
        Dim LvarPto1 As Integer

        LvarTab = fnBuscarTablaC(GvarTabsPD, pTab)
        LvarSQL = LvarTab.Preview()
        LvarPto1 = InStr(LvarSQL, ".NEXTVAL")
        If LvarPto1 > 0 Then
            LvarSQL = "CREATE SEQUENCE S_" & LvarTab.Code & ";" & vbCrLf & "/" & vbCrLf & LvarSQL
        End If
        fnCreateTable = LvarSQL
    End Function
