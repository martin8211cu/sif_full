    Sub sbRelacion(ByVal ptab As String, ByVal pcols As String, ByVal pref As String, ByVal pcolsR As String)
        Dim LvarTab As PdPDM.Table
        Dim LvarRef As PdPDM.Table
        Dim LvarRel As PdPDM.Reference
        Dim LvarRelC As PdPDM.ReferenceJoin
        Dim LvarCod As String
        Dim LvarCols() As String
        Dim i As Integer

        LvarTab = fnBuscarTablaC(GvarTabsPD, ptab)
        i = LvarTab.OutReferences.Count + 1

        LvarCod = "FK" & i & "_" & UCase(ptab)

        LvarRel = GvarPDM.CreateObject(PdPDM.PdPDM_Classes.cls_Reference)
        LvarRel.SetNameAndCode(LvarCod, LvarCod)
        LvarRel.ForeignKeyConstraintName = LvarCod
        LvarRel.ChildTable = LvarTab
        LvarRef = fnBuscarTablaC(GvarTabsPD, pref)
        LvarRel.ParentTable = LvarRef
        LvarRel.ParentKey = fnBuscarKey(LvarRef, pcolsR)
        LvarCols = pcols.Split(",")
        For i = 0 To UBound(LvarCols)
            LvarRelC = LvarRel.Joins.Item(i)
            LvarRelC.ChildTableColumn = fnBuscarCol(LvarTab, LvarCols(i))
        Next i
    End Sub
