    Sub sbIDXname(ByVal pTab As String, ByVal pIdx As String)
        Dim LvarTab As PdPDM.Table
        Dim LvarCol As PdPDM.Column
        Dim LvarIdx As PdPDM.index
        Dim i As Integer, j As Integer

        i = InStr(pIdx, "_")
        Do While InStr(i + 1, pIdx, "_") > 0
            i = InStr(i + 1, pIdx, "_")
        Loop


        LvarTab = fnBuscarTablaC(GvarTabsPD, pTab)
        For Each LvarIdx In LvarTab.Indexes
            If LvarIdx.Name = pIdx Then
                LvarIdx.Code = pTab & Mid(pIdx, i)
                LvarIdx.Name = pTab & Mid(pIdx, i)
                Exit Sub
            End If
        Next
    End Sub

    Sub sbKEYname(ByVal pTab, ByVal pKey)
        Dim LvarTab As PdPDM.Table
        Dim LvarCol As PdPDM.Column
        Dim LvarKey As PdPDM.Key
        Dim i As Integer, j As Integer

        LvarTab = fnBuscarTablaC(GvarTabsPD, pTab)
        LvarTab.PrimaryKey.SetAttribute("ConstraintName", "PK_" & UCase(LvarTab.Code))
    End Sub
    Sub sbLOVname(ByVal pTab, ByVal pCol, ByVal pSec)
