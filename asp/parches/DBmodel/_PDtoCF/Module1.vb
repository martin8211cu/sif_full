    Sub sbIndice(ByVal ptab As String, ByVal pcols As String)
        Dim LvarTab As PdPDM.Table
        Dim LvarIdx As PdPDM.index
        Dim LvarIdxC As PdPDM.IndexColumn
        Dim LvarCod As String
        Dim LvarCols() As String
        Dim i As Integer

        LvarTab = fnBuscarTablaC(GvarTabsPD, ptab)
        i = 1
        For Each LvarIdx In LvarTab.Indexes
            If Not LvarIdx.ForeignKey Then i = i + 1
        Next
        LvarCod = ptab & "_" & Right("00" & i, 2)
        LvarIdx = LvarTab.Indexes.CreateNew(0)
        LvarIdx.SetNameAndCode(LvarCod, LvarCod)
        LvarCols = pcols.Split(",")
        For i = 0 To UBound(LvarCols)
            LvarIdxC = LvarIdx.IndexColumns.CreateNew()
            LvarIdxC.Column = fnBuscarCol(LvarTab, LvarCols(i))
            LvarIdx.IndexColumns.Add(LvarIdxC)
        Next i
        LvarTab.Indexes.Add(LvarIdx)
    End Sub
