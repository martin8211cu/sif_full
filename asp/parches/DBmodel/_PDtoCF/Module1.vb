    Sub sbReglas(ByVal ptab As String, ByVal pcol As String, ByVal plov As String)
        Dim LvarTab2 As PdPDM.Table
        Dim LvarCol1 As PdPDM.Column
        Dim LvarLOVsPD As Array
        Dim LvarLOVsPD2 As Array
        Dim LvarLOVsDE As Array
        Dim LvarLOV1 As String
        Dim LvarLOV2 As String
        Dim i As Integer, j As Integer

        If ptab = GvarTabAntS Then
            LvarTab2 = GvarTabAntO
        Else
            LvarTab2 = fnbuscarTablaC(GvarTabsPD, ptab)
            GvarTabAntS = ptab
            GvarTabAntO = LvarTab2
        End If
        LvarCol1 = fnBuscarCol(LvarTab2, pcol)

        If plov = "" Then
            LvarCol1.ListOfValues = ""
            Exit Sub
        End If
        LvarLOV1 = ""
        LvarLOVsDE = plov.Split(",")
        For i = 0 To UBound(LvarLOVsDE)
            LvarLOV1 = LvarLOV1 & "," & Trim(LvarLOVsDE(i))
        Next i
        LvarLOV1 = LvarLOV1 & ","

        If LvarCol1.ListOfValuesWithoutLabel = "" Then
            LvarLOV2 = ""
        Else
            LvarLOV2 = Replace(LvarCol1.ListOfValues, Chr(13), "")
            LvarLOVsPD = LvarLOV2.Split(Chr(10))
            LvarLOV2 = ""
            For i = 0 To UBound(LvarLOVsPD)
                LvarLOVsPD2 = LvarLOVsPD(i).Split(Chr(9))
                If InStr("<Val", LvarLOV1) Then
                ElseIf InStr(LvarLOV1, "," & Trim(LvarLOVsPD2(0)) & ",") Then
                    If UBound(LvarLOVsPD2) > 0 Then
                        LvarLOV2 = LvarLOV2 & "," & Trim(LvarLOVsPD2(0)) & Chr(9) & Trim(LvarLOVsPD2(1))
                    Else
                        LvarLOV2 = LvarLOV2 & "," & Trim(LvarLOVsPD2(0)) & Chr(9) & "<DESC>"
                    End If
                End If
            Next i
        End If
        For i = 0 To UBound(LvarLOVsDE)
            If InStr(LvarLOV2, "," & Trim(LvarLOVsDE(i)) & Chr(9)) = 0 Then
                LvarLOV2 = LvarLOV2 & "," & Trim(LvarLOVsDE(i)) & Chr(9) & "<DESC>"
            End If
        Next i
        LvarCol1.ListOfValues = Replace(Mid(LvarLOV2, 2), ",", Chr(13) & Chr(10))
        Exit Sub
    End Sub

    Sub sbColumnas(ByVal ptab, ByVal pcol, ByVal ptip, ByVal plon, ByVal pdec, ByVal pide, ByVal pobl, ByVal pdfl)
        Dim LvarTab2 As PdPDM.Table
        Dim LvarCol1 As PdPDM.Column

        If ptab = GvarTabAntS Then
            LvarTab2 = GvarTabAntO
        Else
            LvarTab2 = fnbuscarTablaC(GvarTabsPD, ptab)
            GvarTabAntS = ptab
            GvarTabAntO = LvarTab2
        End If
        LvarCol1 = fnBuscarCol(LvarTab2, pcol)
        If LvarCol1.Mandatory <> (pobl = "1") Then
            LvarCol1.Mandatory = (pobl = "1")
        End If
        Exit Sub
        'MsgBox(LvarTab.Code)
        If ptip = "C" Then
            LvarCol1.DataType = "char(" & plon & ")"
        ElseIf ptip = "V" Then
            LvarCol1.DataType = "varchar(" & plon & ")"
        ElseIf ptip = "B" Then
            LvarCol1.DataType = "binary(" & plon & ")"
        ElseIf ptip = "VB" Then
            LvarCol1.DataType = "varbinary(" & plon & ")"
        ElseIf ptip = "CL" Then
            LvarCol1.DataType = "text"
        ElseIf ptip = "I" Then
            If plon >= 19 Then
                LvarCol1.DataType = "bigint"
            ElseIf plon >= 10 Then
                LvarCol1.DataType = "integer"
            ElseIf plon >= 5 Then
                LvarCol1.DataType = "smallint"
            Else
                LvarCol1.DataType = "tinyint"
            End If
        ElseIf ptip = "N" Then
            If plon = 18 And pdec = 0 Then
                LvarCol1.DataType = "numeric"
            ElseIf pdec = 0 Then
                LvarCol1.DataType = "numeric(" & Trim(CStr(plon)) & ")"
            Else
                LvarCol1.DataType = "numeric(" & Trim(CStr(plon)) & "," & Trim(CStr(pdec)) & ")"
            End If
        ElseIf ptip = "F" Then
            If plon > 15 Then
                LvarCol1.DataType = "double"
            ElseIf plon >= 15 Then
                LvarCol1.DataType = "float"
            Else
                LvarCol1.DataType = "real"
            End If
        ElseIf ptip = "M" Then
            LvarCol1.DataType = "money"
        ElseIf ptip = "L" Then
            LvarCol1.DataType = "bit"
        ElseIf ptip = "D" Then
            LvarCol1.DataType = "datetime"
        ElseIf ptip = "TS" Then
            LvarCol1.DataType = "timestamp"
        End If
        LvarCol1.Identity = (pide = "1")
        Try
            LvarCol1.Mandatory = (pobl = "1")
        Catch ex As Exception

        End Try
        Try
            LvarCol1.DefaultValue = CStr(pdfl)
        Catch ex As Exception

        End Try
    End Sub

