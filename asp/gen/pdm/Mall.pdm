<a:CreationDate>1047338429</a:CreationDate>
<a:Creator>danim</a:Creator>
<a:ModificationDate>1083162775</a:ModificationDate>
<a:Modifier>Administrator</a:Modifier>
<a:EndScript>insert Estado (estado,error,nombre_estado,descripcion_estado) values (  0,0,	&#39;Abierto&#39;,        &#39;Se está modificando el contenido.&#39;)
insert Estado (estado,error,nombre_estado,descripcion_estado) values (100,0,	&#39;Lleno&#39;,          &#39;Listo para pagar.&#39;)

insert Estado (estado,error,nombre_estado,descripcion_estado) values (200,0,	&#39;Pagado&#39;,         &#39;Se prepara el pedido.&#39;)
insert Estado (estado,error,nombre_estado,descripcion_estado) values (201,1,	&#39;Pago rechazado&#39;, &#39;(opc)&#39;)

insert Estado (estado,error,nombre_estado,descripcion_estado) values (300,0,	&#39;Preparado&#39;,      &#39;Listo para enviar.&#39;)

insert Estado (estado,error,nombre_estado,descripcion_estado) values (400,0,	&#39;Enviado&#39;,        &#39;&#39;)
insert Estado (estado,error,nombre_estado,descripcion_estado) values (401,1,	&#39;Reclamo&#39;,        &#39;(opcional)&#39;)

insert Estado (estado,error,nombre_estado,descripcion_estado) values (500,0,	&#39;Cerrado&#39;,        &#39;&#39;)
go
</a:EndScript>
<a:PhysicalOptions>with
    identity_gap = 10
</a:PhysicalOptions>
