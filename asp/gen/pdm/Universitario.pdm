<a:ObjectID>1EF49457-D9EA-4E20-8B71-1A357692DAD1</a:ObjectID>
<a:Name>vRequisitosAlumnos</a:Name>
<a:Code>vRequisitosAlumnos</a:Code>
<a:CreationDate>1077750337</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1084990213</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:Comment>No consultar sin Apersona ni Mcodigo</a:Comment>
<a:SQLQuery>select
   a.Apersona,
   r.Mcodigo,
   r.McodigoRequisito,
   isnull(v.Rresultado,&#39;N&#39;) as Rresultado
from
   MateriaRequisito r,
   vRequisitosAlumnosSP v,
   Alumno a
where
   v.Apersona =* a.Apersona
   and v.Mcodigo =* r.Mcodigo
   and v.McodigoRequisito =* r.McodigoRequisito</a:SQLQuery>
<a:TaggedSQLQuery>select
   a.[{D0FFD46A-CB80-4535-B1A0-B0E815F8DC64}=Apersona],
   r.[{170BE4B7-0D6C-481B-83C5-EE151F491D78}=Mcodigo],
   r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito],
   isnull(v.Rresultado,&#39;N&#39;) as Rresultado
from
   [{BF4B83BC-F071-4C7D-8DD2-3CEA3A990344}=MateriaRequisito] r,
   [{2DFBC0C5-8B42-45CE-B8FF-9F290410CF0B}=vRequisitosAlumnosSP] v,
   [{6D14C810-F2E9-4EA8-AD1F-B4151B25BBC4}=Alumno] a
where
   v.[{148585BB-2405-46BE-9890-03149E3E2799}=Apersona] =* a.[{D0FFD46A-CB80-4535-B1A0-B0E815F8DC64}=Apersona]
   and v.[{87A23D8A-E2DF-40BF-8767-5BC7E48ED731}=Mcodigo] =* r.[{170BE4B7-0D6C-481B-83C5-EE151F491D78}=Mcodigo]
   and v.[{911A6FE1-9A28-463D-9668-DA2961E6CA59}=McodigoRequisito] =* r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito]</a:TaggedSQLQuery>
<c:Columns>
