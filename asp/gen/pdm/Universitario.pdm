<o:View Id="o14">
<a:ObjectID>C7D9646E-854F-4115-91D5-EBF4153D2104</a:ObjectID>
<a:Name>ProfesorGuia</a:Name>
<a:Code>ProfesorGuia</a:Code>
<a:CreationDate>1073940077</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1084990179</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:SQLQuery>select Ppersona as PGpersona, p.*
  from PersonaDatos p, asp..UsuarioRol r
 where r.Usucodigo = p.Usucodigo
   and r.Ecodigo = p.Ecodigo
   and (SScodigo = &#39;EDUC&#39; OR SScodigo = &#39;RH&#39;)
   and SRcodigo = &#39;GUIA&#39;
</a:SQLQuery>
<a:TaggedSQLQuery>select [{B73C4EB1-3622-49C8-ACC6-0DBB9B45A417}=Ppersona] as PGpersona, p.*
  from [{20057669-B6F4-4FF1-B362-2C49CADC380C}=PersonaDatos] p, asp..UsuarioRol r
 where r.Usucodigo = p.[{4397AE2A-E4B9-4422-A5D6-5C7DAFD7F1A7}=Usucodigo]
   and r.Ecodigo = p.[{92DFAB6C-FE5D-4524-8A3E-44B6E3E6A14F}=Ecodigo]
   and (SScodigo = &#39;EDUC&#39; OR SScodigo = &#39;RH&#39;)
   and SRcodigo = &#39;GUIA&#39;</a:TaggedSQLQuery>
<c:Columns>
