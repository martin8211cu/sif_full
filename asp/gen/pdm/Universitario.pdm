<o:View Id="o562">
<a:ObjectID>2DFBC0C5-8B42-45CE-B8FF-9F290410CF0B</a:ObjectID>
<a:Name>vRequisitosAlumnosSP</a:Name>
<a:Code>vRequisitosAlumnosSP</a:Code>
<a:CreationDate>1077749431</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1077750455</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:Comment>No consultar sin Apersona ni Mcodigo

Requisitos S=Aprobados y P=Pendientes de aprobacion, es decir, faltan los N=Faltantes</a:Comment>
<a:SQLQuery>select 	ca.Apersona, 
	r.Mcodigo, 
	r.McodigoRequisito, 
	&#39;S&#39; as Rresultado
  from MateriaRequisito r, Curso c, CursoAlumno ca
 where c.Mcodigo   = r.McodigoRequisito
   and ca.Ccodigo  = c.Ccodigo
   and ca.CAestado &gt;= 20
UNION
select 	ca.Apersona, 
	r.Mcodigo, 
	r.McodigoRequisito, 
	&#39;P&#39; as Rresultado
  from MateriaRequisito r, Curso c, CursoAlumno ca
 where c.Mcodigo   = r.McodigoRequisito
   and ca.Ccodigo  = c.Ccodigo
   and ca.CAestado &lt; 10 
   and not exists (select * from CursoAlumno ca2
			where ca.Ccodigo  = ca2.Ccodigo
			  and ca.Apersona = ca2.Apersona
			  and ca.CAestado &gt;= 20
			)
UNION
select 	am.Apersona, 
	r.Mcodigo, 
	r.McodigoRequisito, 
	&#39;S&#39; as Rresultado
  from MateriaRequisito r, AlumnoMateria am
 where am.Mcodigo   = r.McodigoRequisito
   and am.AMestado &gt;= 20
   and am.AMestado &lt;&gt; 25
</a:SQLQuery>
<a:TaggedSQLQuery>select 	ca.[{65F6ABC3-C2E1-4D91-98E0-244E45A78507}=Apersona], 
	r.[{170BE4B7-0D6C-481B-83C5-EE151F491D78}=Mcodigo], 
	r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito], 
	&#39;S&#39; as Rresultado
  from [{BF4B83BC-F071-4C7D-8DD2-3CEA3A990344}=MateriaRequisito] r, [{DB155B25-086A-40F1-9B51-49BE39DB76E6}=Curso] c, [{80494CDB-9723-4AD6-B331-D35B6DE5FA3D}=CursoAlumno] ca
 where c.[{6F382C2D-E4B6-4839-8251-90F0A6A137BD}=Mcodigo]   = r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito]
   and ca.[{C758001E-2B28-4ED8-B682-50484E26B1F2}=Ccodigo]  = c.[{08A0237F-CF34-4382-9CDA-A7B87DD6137B}=Ccodigo]
   and ca.[{768E3FD4-E291-462F-9D0A-44943660B378}=CAestado] &gt;= 20
UNION
select 	ca.[{65F6ABC3-C2E1-4D91-98E0-244E45A78507}=Apersona], 
	r.[{170BE4B7-0D6C-481B-83C5-EE151F491D78}=Mcodigo], 
	r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito], 
	&#39;P&#39; as Rresultado
  from [{BF4B83BC-F071-4C7D-8DD2-3CEA3A990344}=MateriaRequisito] r, [{DB155B25-086A-40F1-9B51-49BE39DB76E6}=Curso] c, [{80494CDB-9723-4AD6-B331-D35B6DE5FA3D}=CursoAlumno] ca
 where c.[{6F382C2D-E4B6-4839-8251-90F0A6A137BD}=Mcodigo]   = r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito]
   and ca.[{C758001E-2B28-4ED8-B682-50484E26B1F2}=Ccodigo]  = c.[{08A0237F-CF34-4382-9CDA-A7B87DD6137B}=Ccodigo]
   and ca.[{768E3FD4-E291-462F-9D0A-44943660B378}=CAestado] &lt; 10 
   and not exists (select * from CursoAlumno ca2
			where ca.Ccodigo  = ca2.Ccodigo
			  and ca.Apersona = ca2.Apersona
			  and ca.CAestado &gt;= 20
			)
UNION
select 	am.[{0104B266-C9A0-4006-8E6B-F7F7095B379B}=Apersona], 
	r.[{170BE4B7-0D6C-481B-83C5-EE151F491D78}=Mcodigo], 
	r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito], 
	&#39;S&#39; as Rresultado
  from [{BF4B83BC-F071-4C7D-8DD2-3CEA3A990344}=MateriaRequisito] r, [{3F7D3E3A-318F-4FDD-BD43-F632103DCE91}=AlumnoMateria] am
 where am.[{C44659C1-5DCF-4226-8139-8A56B16F45C7}=Mcodigo]   = r.[{1D6497D7-30FD-4394-97A2-90169260B680}=McodigoRequisito]
   and am.[{11F9F454-E501-4A07-BA7A-21B4CE1D7488}=AMestado] &gt;= 20
   and am.[{11F9F454-E501-4A07-BA7A-21B4CE1D7488}=AMestado] &lt;&gt; 25</a:TaggedSQLQuery>
<c:Columns>
