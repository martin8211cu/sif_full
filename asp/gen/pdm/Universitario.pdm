<a:ObjectID>A23A5684-D27B-420C-8073-9A062F74D7CD</a:ObjectID>
<a:Name>vPlanAlumnos</a:Name>
<a:Code>vPlanAlumnos</a:Code>
<a:CreationDate>1077750337</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1084989565</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:Comment>No consultar sin Apersona ni PEScodigo</a:Comment>
<a:SQLQuery>select
   a.Apersona,
   mp.PEScodigo,
   mp.MPcodigo,
   isnull(v.Rresultado,&#39;N&#39;) as Rresultado
from
   MateriaPlan mp,
   vPlanAlumnosSP v,
   Alumno a
where
   v.Apersona =* a.Apersona
   and v.MPcodigo =* mp.MPcodigo</a:SQLQuery>
<a:TaggedSQLQuery>select
   a.[{D0FFD46A-CB80-4535-B1A0-B0E815F8DC64}=Apersona],
   mp.[{C53333FA-501C-4680-8E84-1A4716CD5252}=PEScodigo],
   mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo],
   isnull(v.Rresultado,&#39;N&#39;) as Rresultado
from
   [{A028F38A-3D4F-4A12-BC95-11D71DE1F40B}=MateriaPlan] mp,
   [{D38658C7-7A5E-42CB-8921-47010D1A2B73}=vPlanAlumnosSP] v,
   [{6D14C810-F2E9-4EA8-AD1F-B4151B25BBC4}=Alumno] a
where
   v.[{7290C6BA-8EE4-4A00-9381-7E030CDBD9C6}=Apersona] =* a.[{D0FFD46A-CB80-4535-B1A0-B0E815F8DC64}=Apersona]
   and v.[{FF50EEDD-82BB-4E0D-AEC3-29F7140CCFC1}=MPcodigo] =* mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo]</a:TaggedSQLQuery>
