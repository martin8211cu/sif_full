<o:View Id="o12">
<a:ObjectID>20057669-B6F4-4FF1-B362-2C49CADC380C</a:ObjectID>
<a:Name>PersonaDatos</a:Name>
<a:Code>PersonaDatos</a:Code>
<a:CreationDate>1073940077</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1082070224</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:SQLQuery>select pe.Ecodigo

,pe.Ppersona
    ,u.Usucodigo
    ,u.CEcodigo
    ,u.LOCIdioma
    ,u.Usulogin
    ,u.id_direccion
    ,u.datos_personales

    ,dp.Pid
    ,dp.Pnombre
    ,dp.Papellido1
    ,dp.Papellido2
    ,dp.Pnacimiento
    ,dp.Psexo
    ,dp.Pcasa
    ,dp.Poficina
    ,dp.Pcelular
    ,dp.Pfax
    ,dp.Ppagertel 
    ,dp.Ppagernum
    ,dp.Pemail1
    ,dp.Pemail2
    ,dp.Pweb

    ,dir.Ppais
    ,dir.atencion
    ,dir.direccion1
    ,dir.direccion2
    ,dir.ciudad
    ,dir.estado
    ,dir.codPostal

    ,e.Ecodigo as Ecodigo2

  from PersonaEducativo pe, 
	asp..Empresa e, 
	asp..UsuarioReferencia ur,
 	asp..Usuario u, 
	asp..DatosPersonales dp, 
	asp..Direcciones dir
 where pe.Ppersona = convert(numeric, ur.llave)
   and pe.Ecodigo = e.Ereferencia
   and ur.Ecodigo = e.Ecodigo
   and ur.Usucodigo = u.Usucodigo
   and ur.STabla = &#39;PersonaEducativo&#39;

   and u.datos_personales = dp.datos_personales
   and u.id_direccion = dir.id_direccion
</a:SQLQuery>
<a:TaggedSQLQuery>select
   pe.[{27EF861B-3FE1-41F4-8264-DCC7FA648115}=Ecodigo],
   pe.[{036BEB22-777E-49CA-828E-D40DC9011FB5}=Ppersona],
   u.Usucodigo,
   u.CEcodigo,
   u.LOCIdioma,
   u.Usulogin,
   u.id_direccion,
   u.datos_personales,
   dp.Pid,
   dp.Pnombre,
   dp.Papellido1,
   dp.Papellido2,
   dp.Pnacimiento,
   dp.Psexo,
   dp.Pcasa,
   dp.Poficina,
   dp.Pcelular,
   dp.Pfax,
   dp.Ppagertel,
   dp.Ppagernum,
   dp.Pemail1,
   dp.Pemail2,
   dp.Pweb,
   dir.Ppais,
   dir.atencion,
   dir.direccion1,
   dir.direccion2,
   dir.ciudad,
   dir.estado,
   dir.codPostal,
   e.Ecodigo as Ecodigo2
from
   [{54A595A0-9273-446F-B409-CBC17EF1759D}=PersonaEducativo] pe,
   asp..Empresa e,
   asp..UsuarioReferencia ur,
   asp..Usuario u,
   asp..DatosPersonales dp,
   asp..Direcciones dir
where
   pe.[{036BEB22-777E-49CA-828E-D40DC9011FB5}=Ppersona] = convert(numeric, ur.llave)
   and pe.[{27EF861B-3FE1-41F4-8264-DCC7FA648115}=Ecodigo] = e.Ereferencia
   and ur.Ecodigo = e.Ecodigo
   and ur.Usucodigo = u.Usucodigo
   and ur.STabla = &#39;PersonaEducativo&#39;
   and u.datos_personales = dp.datos_personales
   and u.id_direccion = dir.id_direccion
</a:TaggedSQLQuery>
