<o:View Id="o566">
<a:ObjectID>D38658C7-7A5E-42CB-8921-47010D1A2B73</a:ObjectID>
<a:Name>vPlanAlumnosSP</a:Name>
<a:Code>vPlanAlumnosSP</a:Code>
<a:CreationDate>1077749431</a:CreationDate>
<a:Creator>obonilla66</a:Creator>
<a:ModificationDate>1077900350</a:ModificationDate>
<a:Modifier>obonilla66</a:Modifier>
<a:Comment>No consultar sin Apersona ni PEScodigo

Requisitos S=Aprobados y P=Pendientes de aprobacion, es decir, faltan los N=Faltantes</a:Comment>
<a:SQLQuery>select 	ca.Apersona, 
	mp.PEScodigo, 
	mp.MPcodigo, 
	&#39;S&#39; as Rresultado
  from MateriaPlan mp, Curso c, CursoAlumno ca
 where c.Mcodigo   = mp.Mcodigo
   and ca.Ccodigo  = c.Ccodigo
   and ca.CAestado &gt;= 20
UNION
select 	ca.Apersona, 
	mp.PEScodigo, 
	mp.MPcodigo, 
	&#39;P&#39; as Rresultado
  from MateriaPlan mp, Curso c, CursoAlumno ca
 where c.Mcodigo   = mp.Mcodigo
   and ca.Ccodigo  = c.Ccodigo
   and ca.CAestado &lt; 10 
   and not exists (select * from CursoAlumno ca2
			where ca.Ccodigo  = ca2.Ccodigo
			  and ca.Apersona = ca2.Apersona
			  and ca.CAestado &gt;= 20
			)
UNION
select 	am.Apersona, 
	mp.PEScodigo, 
	mp.MPcodigo, 
	&#39;S&#39; as Rresultado
  from MateriaPlan mp, AlumnoMateria am
 where am.MPcodigo   = mp.MPcodigo
   and am.AMestado &gt;= 20
   and am.AMestado &lt;&gt; 25
</a:SQLQuery>
<a:TaggedSQLQuery>select 	ca.[{65F6ABC3-C2E1-4D91-98E0-244E45A78507}=Apersona], 
	mp.[{C53333FA-501C-4680-8E84-1A4716CD5252}=PEScodigo], 
	mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo], 
	&#39;S&#39; as Rresultado
  from [{A028F38A-3D4F-4A12-BC95-11D71DE1F40B}=MateriaPlan] mp, [{DB155B25-086A-40F1-9B51-49BE39DB76E6}=Curso] c, [{80494CDB-9723-4AD6-B331-D35B6DE5FA3D}=CursoAlumno] ca
 where c.[{6F382C2D-E4B6-4839-8251-90F0A6A137BD}=Mcodigo]   = mp.[{FB832763-6E72-4A2A-86F6-A179B50D184F}=Mcodigo]
   and ca.[{C758001E-2B28-4ED8-B682-50484E26B1F2}=Ccodigo]  = c.[{08A0237F-CF34-4382-9CDA-A7B87DD6137B}=Ccodigo]
   and ca.[{768E3FD4-E291-462F-9D0A-44943660B378}=CAestado] &gt;= 20
UNION
select 	ca.[{65F6ABC3-C2E1-4D91-98E0-244E45A78507}=Apersona], 
	mp.[{C53333FA-501C-4680-8E84-1A4716CD5252}=PEScodigo], 
	mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo], 
	&#39;P&#39; as Rresultado
  from [{A028F38A-3D4F-4A12-BC95-11D71DE1F40B}=MateriaPlan] mp, [{DB155B25-086A-40F1-9B51-49BE39DB76E6}=Curso] c, [{80494CDB-9723-4AD6-B331-D35B6DE5FA3D}=CursoAlumno] ca
 where c.[{6F382C2D-E4B6-4839-8251-90F0A6A137BD}=Mcodigo]   = mp.[{FB832763-6E72-4A2A-86F6-A179B50D184F}=Mcodigo]
   and ca.[{C758001E-2B28-4ED8-B682-50484E26B1F2}=Ccodigo]  = c.[{08A0237F-CF34-4382-9CDA-A7B87DD6137B}=Ccodigo]
   and ca.[{768E3FD4-E291-462F-9D0A-44943660B378}=CAestado] &lt; 10 
   and not exists (select * from CursoAlumno ca2
			where ca.Ccodigo  = ca2.Ccodigo
			  and ca.Apersona = ca2.Apersona
			  and ca.CAestado &gt;= 20
			)
UNION
select 	am.[{0104B266-C9A0-4006-8E6B-F7F7095B379B}=Apersona], 
	mp.[{C53333FA-501C-4680-8E84-1A4716CD5252}=PEScodigo], 
	mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo], 
	&#39;S&#39; as Rresultado
  from [{A028F38A-3D4F-4A12-BC95-11D71DE1F40B}=MateriaPlan] mp, [{3F7D3E3A-318F-4FDD-BD43-F632103DCE91}=AlumnoMateria] am
 where am.[{75A4612A-9650-40F6-BB26-9A2BEF76EC58}=MPcodigo]   = mp.[{6C74B841-BB73-43C9-8F3E-6C6AE2B7E0F0}=MPcodigo]
   and am.[{11F9F454-E501-4A07-BA7A-21B4CE1D7488}=AMestado] &gt;= 20
   and am.[{11F9F454-E501-4A07-BA7A-21B4CE1D7488}=AMestado] &lt;&gt; 25</a:TaggedSQLQuery>
