<o:Table Id="o38">
<a:ObjectID>769C9E08-E488-41D0-8830-1B08D3889543</a:ObjectID>
<a:Name>TipoTarjeta</a:Name>
<a:Code>TipoTarjeta</a:Code>
<a:CreationDate>1047659262</a:CreationDate>
<a:Creator>danim</a:Creator>
<a:ModificationDate>1069279389</a:ModificationDate>
<a:Modifier>Administrator</a:Modifier>
<a:EndScript>if not exists (select 1 from TipoTarjeta where tc_tipo = &#39;AMEX&#39;)
insert TipoTarjeta (tc_tipo, nombre_tipo_tarjeta, mascara)
values (&#39;AMEX&#39;, &#39;American Express&#39;, &#39;0000-000000-00000&#39;)

if not exists (select 1 from TipoTarjeta where tc_tipo = &#39;MC&#39;)
insert TipoTarjeta (tc_tipo, nombre_tipo_tarjeta, mascara)
values (&#39;MC&#39;, &#39;Master Card&#39;, &#39;0000-0000-0000-0000&#39;)

if not exists (select 1 from TipoTarjeta where tc_tipo = &#39;VISA&#39;)
insert TipoTarjeta (tc_tipo, nombre_tipo_tarjeta, mascara)
values (&#39;VISA&#39;, &#39;Visa&#39;, &#39;0000-0000-0000-0000&#39;)
go</a:EndScript>
<a:PhysicalOptions>with
    identity_gap = 100
</a:PhysicalOptions>
