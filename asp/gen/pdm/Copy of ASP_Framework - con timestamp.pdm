<c:Views>
<o:View Id="o169">
<a:ObjectID>DDF8DB0C-2A35-469F-8BFF-9D2C65E6BDE3</a:ObjectID>
<a:Name>vUsuarioProcesosCalc</a:Name>
<a:Code>vUsuarioProcesosCalc</a:Code>
<a:CreationDate>1075742282</a:CreationDate>
<a:Creator>marcel</a:Creator>
<a:ModificationDate>1081876027</a:ModificationDate>
<a:Modifier>Administrator</a:Modifier>
<a:SQLQuery>select up.Usucodigo,
       up.Ecodigo,
       up.SScodigo,
       up.SMcodigo,
       up.SPcodigo
  from UsuarioProceso up, Empresa e, ModulosCuentaE mc
 where up.UPtipo = &#39;G&#39;
   and e.Ecodigo = up.Ecodigo
   and mc.CEcodigo = e.CEcodigo
   and mc.SScodigo = up.SScodigo
   and mc.SMcodigo = up.SMcodigo
UNION
select ur.Usucodigo,
       ur.Ecodigo,
       pr.SScodigo,
       pr.SMcodigo,
       pr.SPcodigo
  from UsuarioRol ur, SProcesosRol pr, Empresa e, ModulosCuentaE mc
 where ur.SScodigo = pr.SScodigo
   and ur.SRcodigo = pr.SRcodigo
   and e.Ecodigo   = ur.Ecodigo
   and mc.CEcodigo = e.CEcodigo
   and mc.SScodigo = pr.SScodigo
   and mc.SMcodigo = pr.SMcodigo
   and not exists (
select * from UsuarioProceso up
where up.Usucodigo = ur.Usucodigo
   and up.SScodigo  = pr.SScodigo
   and up.SMcodigo  = pr.SMcodigo
   and up.SPcodigo  = pr.SPcodigo
   and up.UPtipo    = &#39;R&#39;
   and e.Ecodigo    = up.Ecodigo
)
</a:SQLQuery>
<a:TaggedSQLQuery>select up.[{49514625-01D2-4A8B-9064-FF9CC91B83FA}=Usucodigo],
       up.[{BAEF6E64-D2F8-44CD-B9A6-6AD657984272}=Ecodigo],
       up.[{063B8710-9D00-4812-BD4D-9E810393A390}=SScodigo],
       up.[{799322FF-CBCD-48DD-B25E-30A968EAF080}=SMcodigo],
       up.[{BB743EA8-8017-4718-B757-FB5AA2BB9722}=SPcodigo]
  from [{6CAAA632-B674-42AD-9AF3-B4EFB43E56C7}=UsuarioProceso] up, [{03EF216E-7ECE-4329-A35C-083DD3B75397}=Empresa] e, [{119E3AF5-7B11-4AEB-9C4F-9447125D12E9}=ModulosCuentaE] mc
 where up.[{D2C4DAD5-B260-4E68-9E44-80243023B16B}=UPtipo] = &#39;G&#39;
   and e.[{06AA1BD4-9A68-427F-90A3-3BCEADD39857}=Ecodigo] = up.[{BAEF6E64-D2F8-44CD-B9A6-6AD657984272}=Ecodigo]
   and mc.[{F3FF9EE6-F9E7-40FA-A0AC-FB50BF8A2D2A}=CEcodigo] = e.[{0C13E78D-09A8-4BFB-9484-3880DDF0CBF9}=CEcodigo]
   and mc.[{5BD86583-52BC-4102-85DD-81010E2472D9}=SScodigo] = up.[{063B8710-9D00-4812-BD4D-9E810393A390}=SScodigo]
   and mc.[{65308A75-CEDA-4B09-98EE-D95978D22512}=SMcodigo] = up.[{799322FF-CBCD-48DD-B25E-30A968EAF080}=SMcodigo]
UNION
select ur.[{9AD909C1-A067-4DE3-97FC-21322B12DF15}=Usucodigo],
       ur.[{86D2CFDD-3CC6-444D-ACBD-9BDEECA00BAE}=Ecodigo],
       pr.[{CA60D276-03BB-47AA-AC5D-BCBCC7EDEEA7}=SScodigo],
       pr.[{D16DC6EC-29ED-4BA0-8FFE-B5A2CAB4FDE9}=SMcodigo],
       pr.[{E99CCC4C-07A5-4C58-9F07-9B637A3F669B}=SPcodigo]
  from [{A1ED8592-A019-4D83-BE25-C703E9A43B3F}=UsuarioRol] ur, [{48E4F8D9-18DE-4E4A-814C-EFA64FD5E703}=SProcesosRol] pr, [{03EF216E-7ECE-4329-A35C-083DD3B75397}=Empresa] e, [{119E3AF5-7B11-4AEB-9C4F-9447125D12E9}=ModulosCuentaE] mc
 where ur.[{E144CB8C-8BE5-4B78-92D4-983E9125B346}=SScodigo] = pr.[{CA60D276-03BB-47AA-AC5D-BCBCC7EDEEA7}=SScodigo]
   and ur.[{AE23DABF-416F-4BCB-A7F2-104C3691FF59}=SRcodigo] = pr.[{DA4A8A42-8075-47F7-B9E0-0F1C30939414}=SRcodigo]
   and e.[{06AA1BD4-9A68-427F-90A3-3BCEADD39857}=Ecodigo]   = ur.[{86D2CFDD-3CC6-444D-ACBD-9BDEECA00BAE}=Ecodigo]
   and mc.[{F3FF9EE6-F9E7-40FA-A0AC-FB50BF8A2D2A}=CEcodigo] = e.[{0C13E78D-09A8-4BFB-9484-3880DDF0CBF9}=CEcodigo]
   and mc.[{5BD86583-52BC-4102-85DD-81010E2472D9}=SScodigo] = pr.[{CA60D276-03BB-47AA-AC5D-BCBCC7EDEEA7}=SScodigo]
   and mc.[{65308A75-CEDA-4B09-98EE-D95978D22512}=SMcodigo] = pr.[{D16DC6EC-29ED-4BA0-8FFE-B5A2CAB4FDE9}=SMcodigo]
   and not exists (
select * from UsuarioProceso up
where up.Usucodigo = ur.Usucodigo
   and up.SScodigo  = pr.SScodigo
   and up.SMcodigo  = pr.SMcodigo
   and up.SPcodigo  = pr.SPcodigo
   and up.UPtipo    = &#39;R&#39;
   and e.Ecodigo    = up.Ecodigo
)</a:TaggedSQLQuery>
