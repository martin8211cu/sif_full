<c:Triggers>
<o:Trigger Id="o231">
<a:ObjectID>76DCA9F5-4726-43D9-8469-50ADA4DF8382</a:ObjectID>
<a:Name>trinsUsuario</a:Name>
<a:Code>trinsUsuario</a:Code>
<a:Text>create trigger trinsUsuario	on Usuario for insert, update
as

declare
	@cta varchar(10),
    @ulogin varchar(30),
	@uid numeric(18),
	@d datetime

set nocount on
set rowcount 1

while (1=1) begin
	select @uid = null
	select @uid = Usucodigo
	from Usuario
	where Usulogin = &#39;*&#39;
    
	if @uid is null break

	while (1=1) begin
		select @ulogin
			= char(rand() * 26 + 97)
			+ char(rand() * 26 + 97)
			+ char(rand() * 26 + 97)
			+ char(rand() * 26 + 97)
			+ char(rand() * 26 + 97)
			+ &#39;-&#39;
			+ char(rand() * 8 + 50)
			+ char(rand() * 8 + 50)
		if not exists (select * from Usuario where Usulogin = @ulogin)
			break
	end

	update Usuario
	set Usulogin = @ulogin
	where @uid = Usucodigo
	  and Usulogin = &#39;*&#39;
end

set rowcount 0

</a:Text>
<a:CreationDate>1072716881</a:CreationDate>
<a:Creator>marcel</a:Creator>
<a:ModificationDate>1072717076</a:ModificationDate>
<a:Modifier>marcel</a:Modifier>
<a:Time/>
</o:Trigger>
</c:Triggers>
