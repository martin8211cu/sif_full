	<queryString><![CDATA[select
	s.SSorden, m.SMorden, p.SPorden, n.SMNpath,
	s.SScodigo, s.SSdescripcion,
	m.SMcodigo, m.SMdescripcion,
	p.SPcodigo, p.SPhomeuri,
	n.SMNtipo, replicate(' ', coalesce (n.SMNnivel, 0)*2)||
		coalesce (n.SMNtitulo, p.SPdescripcion) SMNtitulo,
	n.SMNorden, n.SMNenConstruccion
from SSistemas s join SModulos m
  on m.SScodigo = s.SScodigo
left outer join SMenues n
  on n.SScodigo = m.SScodigo
 and n.SMcodigo = m.SMcodigo
left outer join SProcesos p
  on p.SScodigo = n.SScodigo
 and p.SMcodigo = n.SMcodigo
 and p.SPcodigo = n.SPcodigo
where ($P{SScodigo} = ' ' or s.SScodigo = $P{SScodigo})
  and ($P{SMcodigo} = ' ' or m.SMcodigo = $P{SMcodigo})

union all

select
	s.SSorden, m.SMorden, p.SPorden, '' SMNpath,
	s.SScodigo, s.SSdescripcion,
	m.SMcodigo, m.SMdescripcion,
	p.SPcodigo, p.SPhomeuri, 
	'-' SMNtipo, p.SPdescripcion SMNtitulo,
	SPorden SMNorden, 0 SMNenConstruccion
from SSistemas s
join SModulos m
  on m.SScodigo = s.SScodigo
join SProcesos p
  on p.SScodigo = m.SScodigo
 and p.SMcodigo = m.SMcodigo
where ($P{SScodigo} = ' ' or s.SScodigo = $P{SScodigo})
  and ($P{SMcodigo} = ' ' or m.SMcodigo = $P{SMcodigo})
  and not exists (
	select * from SMenues n
	where n.SScodigo = p.SScodigo
	  and n.SMcodigo = p.SMcodigo
	  and n.SPcodigo = p.SPcodigo
)
order by SSorden, SScodigo, SMorden, SMcodigo, SMNpath, SMNorden, SPorden, SPcodigo]]></queryString>
