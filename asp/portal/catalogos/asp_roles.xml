	<queryString><![CDATA[select s.SScodigo, s.SSdescripcion, 
	m.SMcodigo, m.SMdescripcion, 
	p.SPcodigo, p.SPdescripcion, p.SPanonimo, p.SPpublico,
	r.SRcodigo, r.SRdescripcion
from SSistemas s
join SModulos m
  on m.SScodigo = s.SScodigo
join SProcesos p
  on p.SScodigo = m.SScodigo
 and p.SMcodigo = m.SMcodigo
left outer join SProcesosRol pr
  on pr.SScodigo = p.SScodigo
 and pr.SMcodigo = p.SMcodigo
 and pr.SPcodigo = p.SPcodigo
left outer join SRoles r
  on pr.SScodigo = r.SScodigo
 and pr.SRcodigo = r.SRcodigo
where ($P{SScodigo} = ' ' or s.SScodigo = $P{SScodigo})
  and ($P{SMcodigo} = ' ' or m.SMcodigo = $P{SMcodigo})
order by s.SSorden, s.SScodigo, m.SMorden, m.SMcodigo, p.SPorden, p.SPcodigo]]></queryString>
