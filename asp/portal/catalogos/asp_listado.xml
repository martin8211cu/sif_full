  on c.SScodigo = p.SScodigo
 and c.SMcodigo = p.SMcodigo
 and c.SPcodigo = p.SPcodigo
where ($P{SScodigo} = ' ' or s.SScodigo = $P{SScodigo})
  and ($P{SMcodigo} = ' ' or m.SMcodigo = $P{SMcodigo})
order by s.SSorden, s.SScodigo, m.SMorden, m.SMcodigo, p.SPorden, p.SPcodigo, c.SCuri
]]></queryString>
