	<queryString><![CDATA[select s.SScodigo, s.SSdescripcion, s.SShomeuri, s.SSmenu, s.SSorden,
	m.SMcodigo, m.SMdescripcion, m.SMhomeuri, m.SMmenu, m.SMorden,
	p.SPcodigo, p.SPdescripcion, p.SPhomeuri, p.SPmenu, p.SPorden, p.SPpublico, p.SPanonimo,
	c.SCtipo, c.SCuri
from SSistemas s
left outer join SModulos m
  on m.SScodigo = s.SScodigo
left outer join SProcesos p
  on p.SScodigo = m.SScodigo
 and p.SMcodigo = m.SMcodigo
