\par {\pntext\pard\plain\ltrpar \rtlch\fcs1 \af1\afs20 \ltrch\fcs0 \f1\fs20\lang5130\langfe1033\langnp5130\insrsid1390189 \hich\af1\dbch\af0\loch\f1 1\tab}}\pard \ltrpar\ql \fi-360\li720\ri0\nowidctlpar\tx720\wrapdefault{\*\pn \pnlvlbody\ilvl0\ls1\pnrnot0
