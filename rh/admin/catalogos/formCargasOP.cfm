<script language="JavaScript1.2">
	function valida() {
		var f = document.form1;
		var estado = f.ECcodigo.disabled;
		f.ECcodigo.disabled = false;
		if (f.ECcodigo.value == ""){
			alert ("<cfoutput>#MSG_DebeDigitarElCodigoDeLaCarga#</cfoutput>");
			f.ECcodigo.focus();
			return false;
		}
		f.ECcodigo.disabled = estado;
		if (f.ECdescripcion.value == ""){
			alert ("<cfoutput>#MSG_DebeDigitarLaDescripcionDeLaCarga#</cfoutput>");
			f.ECdescripcion.focus();
			return false;
		}

		<cfif modo NEQ "ALTA"> return validaD(); </cfif>
		return true;
	}




	function validaD() {
		var f = document.form1;
		if (f.DCcodigo.value == ""){
			alert ("<cfoutput>#MSG_DebeDigitarElCodigoDeLaLineaDeLaCarga#</cfoutput>");
			f.DCcodigo.focus();
			return false;
		}
		<cfif modoDet NEQ "CAMBIO">
			else{
				DCcodigo = f.DCcodigo.value;
				if( DCcodigo.indexOf(' ',0) != -1){
					alert ("<cfoutput>#MSG_El_codigo_de_la_linea_de_la_carga_no_debe_contener_espacios#</cfoutput>");
					f.DCcodigo.focus();
					return false;
				}
			}
		</cfif>
		if (f.SNcodigo.value == ""){
			alert ("<cfoutput>#MSG_DebeSeleccionarElProveedor#</cfoutput>");
			f.SNnumero.focus();
			return false;
		}
		if (f.DCtipo.value== "1"){
		if (f.SNcodigoref.value == ""){
			alert ("<cfoutput>#MSG_DebeSeleccionarElSocioDeNegocio#</cfoutput>");
			//f.SNcodigoref.focus();
			return false;
		} }

		if (f.DCmetodo.value == ""){
			alert ("<cfoutput>#MSG_DebeSeleccionarAlgunMetodoDeCalculo#</cfoutput>");
			f.DCmetodo.focus();
			return false;
		}
		if (f.DCdescripcion.value == ""){
			alert ("<cfoutput>#MSG_DebeDigitarLaDescripcionDeLalineaDeLaCarga#</cfoutput>");
			f.DCdescripcion.focus();
			return false;
		}

		if (f.DCvaloremp.value == "" || f.DCvaloremp.value == " " || qf(f.DCvaloremp.value) < 0 ){
			alert ("<cfoutput>#MSG_DebeDigitarElValorDelEmpleadoMayorOIgualQueCero#</cfoutput>");
			f.DCvaloremp.select();
			return false;
		}
		else
			f.DCvaloremp.value =  qf(f.DCvaloremp.value);

		if (f.DCvalorpat.value == "" || f.DCvalorpat.value == " " || qf(f.DCvalorpat.value) < 0){
			alert ("<cfoutput>#MSG_DebeDigitarElValorDelPatronoMayorQueCero#</cfoutput>");
			f.DCvalorpat.select();
			return false;
		}
		else
			f.DCvalorpat.value =  qf(f.DCvalorpat.value);

		<!--- Validar el tipo de rango cuando aplica --->
		if (f.DCtiporango.value != '0') {
			if (f.DCtiporango.value == '1') {
				if (parseFloat(qf(f.DCrangomin1.value)) > parseFloat(qf(f.DCrangomax1.value))) {
					alert ("<cfoutput>#MSG_ElRangoMinimoDebeSerMenorAlRangoMaximo#</cfoutput>");
					return false;
				}
			}
			if (f.DCtiporango.value == '2') {
				if (parseFloat(qf(f.DCrangomin2.value)) > parseFloat(qf(f.DCrangomax2.value))) {
					alert ("<cfoutput>#LB_ElRangoMinimoDebeSerMenorAlRangoMaximo#</cfoutput>");
					return false;
				}
			}
		}
		f.DCcodigo.disabled = false;
		f.DCrangomin1.value = qf(f.DCrangomin1.value);
		f.DCrangomin2.value = qf(f.DCrangomin2.value);
		f.DCrangomax1.value = qf(f.DCrangomax1.value);
		f.DCrangomax2.value = qf(f.DCrangomax2.value);

		return true;
	}

	// En un hidden manda si se cambió o no los datos del encabezado, con el fin de saber si se debe actualizar el mismo
	function EncabezadoCambio() {
		var f = document.form1;
		f.CambioEncabezado.value = '0';
		if (f.ECdescripcion.defaultValue != f.ECdescripcion.value)  {
			f.CambioEncabezado.value = '1';
			return;
		}
		if (f.ECauto.defaultValue != f.ECauto.value)  {
			f.CambioEncabezado.value = '1';
			return;
		}
		if (f.ECprioridad.defaultValue != f.ECprioridad.value)  {
			f.CambioEncabezado.value = '1';
			return;
		}


		return false;
	}

