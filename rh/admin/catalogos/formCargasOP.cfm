                <input name="BorrarD" class="btnEliminar" tabindex="3" type="submit" value="#BTN_borralinea#" onclick="javascript:if (confirm('#MSG_DeseaBorrarEstaLineaDeLaCarga#')) {document.form1.ECcodigo.disabled = false; return true;} else return false;">
