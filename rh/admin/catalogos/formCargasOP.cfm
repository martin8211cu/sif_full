<!--- VERIFICA PARAMETRO PARA MOSTRAR CLAVE Y CODIGO UTILIZADO EN PROCESO DE INTERFAZ CON SAP (OE) --->
<cfinvoke component="rh.Componentes.RHParametros" method="get" datasource="#session.DSN#" ecodigo="#session.Ecodigo#" pvalor="2010" default="" returnvariable="InterfazCatalogos"/>

<cfif modo NEQ "ALTA">

	<!--- Carga --->
	<cfquery name="rsCarga" datasource="#Session.DSN#">
		select ECid, ECcodigo, ECdescripcion, ECfecha, ECauto, ECprioridad, ts_rversion, ECCreditoFiscal, ECSalarioBaseC, ECresumido,RHCSATid
		from ECargas
		where Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
		  and ECid = <cfqueryparam cfsqltype="cf_sql_numeric" value="#form.ECid#">
	</cfquery>

	<!--- Verifica si la carga está siendo utilizada en Cargas de Empleados, para validar el borrado --->

	<cfquery name="rsExisteCargaEmpleado" datasource="#Session.DSN#">
		select 1
		from DCargas a, CargasEmpleado b
		where a.Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
			and a.ECid = <cfqueryparam cfsqltype="cf_sql_numeric" value="#form.ECid#">
			and a.DClinea = b.DClinea
	</cfquery>

	<cfset existeCargaEmpleado = false>
	<cfif rsExisteCargaEmpleado.recordCount GT 0>
		<cfset existeCargaEmpleado = true>
	</cfif>

	<cfif modoDet NEQ "ALTA">
		<!--- Detalle de la Línea --->

		<cfquery name="rsLinea" datasource="#Session.DSN#">
			select a.DClinea, a.SNcodigo, a.DCcodigo, a.DCmetodo, a.DCdescripcion, a.DCvaloremp,
				 a.DCvalorpat, a.DCprovision, a.DCnorenta, a.DCtipo, coalesce (a.SNreferencia, -1) as SNreferencia,
				 a.DCcuentac, a.DCtiporango, a.DCrangomin, a.DCrangomax,DCSumarizarLiq,DCMostrarLiq,
				 a.DCclave, a.DCcodigoext, a.DCcalcInteres, a.DCporcInteres, a.DCaplica, a.ts_rversion,
				 a.DCvsmg, a.DCdisminuyeSBC, a.DCdbc, a.DCusaSMGA, a.DCnomostrar, a.DCUsaUMA, a.DCEsExcedente,DCConsideraFaltas
			from DCargas a
			where a.Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
			  and a.ECid = <cfqueryparam cfsqltype="cf_sql_numeric" value="#form.ECid#">
			  and a.DClinea = <cfqueryparam cfsqltype="cf_sql_numeric" value="#form.DClinea#">
			order by a.DClinea
		</cfquery>

		<!--- Nombre del Socio --->
		<cfquery name="rsNombreSocio" datasource="#Session.DSN#">
			select SNcodigo, SNnumero, SNidentificacion, SNnombre from SNegocios
			where Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
			  and SNcodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#rsLinea.SNcodigo#">
		</cfquery>

		<!--- Nombre del Socio Ref. --->
		<cfquery name="rsNombreSocioRef" datasource="#Session.DSN#">
			select SNcodigo, SNnumero, SNidentificacion, SNnombre
			from SNegocios
			where Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
			  and SNcodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#rsLinea.SNreferencia#">
		</cfquery>
	</cfif>
</cfif>

