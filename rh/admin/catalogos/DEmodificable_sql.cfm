			<cfif isdefined ('form.DEinfo1')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEinfo2')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEinfo3')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEinfo4')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEinfo5')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEdatos1')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEdatos2')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEdatos3')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEinfo1')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEinfo2')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEobs1')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.FEobs2')>1<cfelse>0</cfif>,
