			ZEid, DEsdi, 
			DEobs1, DEobs2, DEobs3,
			DEobs4, DEobs5,DEdato1,
			DEdato2, DEdato3, DEdato4, 
		    DEdato5,DEdato6, DEdato7, 
			DEinfo1, DEinfo2, DEinfo3,
			DEinfo4, DEinfo5, FEdatos1,
  			FEdatos2,FEdatos3,FEinfo1,FEinfo2,FEobs1, FEobs2  ,    
