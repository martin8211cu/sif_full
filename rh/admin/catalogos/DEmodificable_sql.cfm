			DEpassword=<cfif isdefined ('form.Pass')>1<cfelse>0</cfif>, 
			Ppais=<cfif isdefined ('form.Pais')>1<cfelse>0</cfif>, 
			DESeguroSocial=<cfif isdefined ('form.NumSS')>1<cfelse>0</cfif>,			
			ZEid=<cfif isdefined ('form.Zona')>1<cfelse>0</cfif>, 
