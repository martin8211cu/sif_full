			<cfif isdefined ('form.Pais')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.NumSS')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.Zona')>1<cfelse>0</cfif>,
			0,
			<cfif isdefined ('form.DEobs1')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEobs2')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEobs3')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEobs4')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEobs5')>1<cfelse>0</cfif>,
			<cfif isdefined ('form.DEdato1')>1<cfelse>0</cfif>,
