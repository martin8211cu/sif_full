			FEdatos3=<cfif isdefined ('form.FEdatos3')>1<cfelse>0</cfif>,
			FEinfo1=<cfif isdefined ('form.FEinfo1')>1<cfelse>0</cfif>,
			FEinfo2=<cfif isdefined ('form.FEinfo2')>1<cfelse>0</cfif>,
			FEobs1=<cfif isdefined ('form.FEobs1')>1<cfelse>0</cfif>, 
			FEobs2=<cfif isdefined ('form.FEobs2')>1<cfelse>0</cfif>,
