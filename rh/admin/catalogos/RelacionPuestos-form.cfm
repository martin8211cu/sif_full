<script language="javascript" type="text/javascript">
	function inhabilitarValidacion() {
	<cfif modo EQ "CAMBIO">
		objForm.RHPcodigo.required = false;
		objForm.HYHEcodigo.required = false;
		objForm.HYHGcodigo.required = false;
		objForm.HYIHgrado.required = false;
		objForm.HYMRcodigo.required = false;
		objForm.HYCPgrado.required = false;
		objForm.HYLAcodigo.required = false;
		objForm.HYMgrado.required = false;
	</cfif>
	}

	function habilitarValidacion() {
	<cfif modo EQ "CAMBIO">
		objForm.RHPcodigo.required = true;
		objForm.HYHEcodigo.required = true;
		objForm.HYHGcodigo.required = true;
		objForm.HYIHgrado.required = true;
		objForm.HYMRcodigo.required = true;
		objForm.HYCPgrado.required = true;
		objForm.HYLAcodigo.required = true;
		objForm.HYMgrado.required = true;
	</cfif>
	}

	qFormAPI.errorColor = "#FFFFCC";
	objForm = new qForm("form1");
<cfoutput>
	<cfif modo EQ "CAMBIO">
		objForm.RHPcodigo.required = true;
		objForm.RHPcodigo.description = "#MSG_Puesto#";
		objForm.HYHEcodigo.required = true;
		objForm.HYHEcodigo.description = "#MSG_HabilidadEspecializada#";
		objForm.HYHGcodigo.required = true;
		objForm.HYHGcodigo.description = "#MSG_HabilidadDeGerencia#";
		objForm.HYIHgrado.required = true;
		objForm.HYIHgrado.description = "#MSG_IteraccionHumana#";
		objForm.HYMRcodigo.required = true;
		objForm.HYMRcodigo.description = "#MSG_MarcoDeReferencia#";
		objForm.HYCPgrado.required = true;
		objForm.HYCPgrado.description = "#MSG_ComplejidadDePensamiento#";
		objForm.HYLAcodigo.required = true;
		objForm.HYLAcodigo.description = "#MSG_LibertadParaActuar#";
		objForm.HYMgrado.required = true;
		objForm.HYMgrado.description = "#MSG_Magnitud#";
		refill(document.form1);
	<cfelse>
		objForm.HYERVdescripcion.required = true;
		objForm.HYERVdescripcion.description = "#MSG_Descripcion#";
		objForm.HYERVfecha.required = true;
		objForm.HYERVfecha.description = "#MSG_FechaDeVigencia#";
	</cfif>
</cfoutput>
	<cfif modo NEQ "ALTA">
		document.form1.btnAplicar.focus();
	<cfelse>
		document.form1.HYERVdescripcion.focus();
	</cfif>
</script>
