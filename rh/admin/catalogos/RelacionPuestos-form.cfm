<cfif isdefined("Url.HYERVid") and not isdefined("Form.HYERVid")>
	<cfset Form.HYERVid = Url.HYERVid>
</cfif>

<cfif isdefined("Form.HYERVid") and Len(Trim(Form.HYERVid)) NEQ 0>
	<cfset modo = "CAMBIO">
<cfelse>
	<cfset modo = "ALTA">
</cfif>

<cfif isdefined("Form.HYDRVlinea") and Len(Trim(Form.HYDRVlinea)) NEQ 0>
	<cfset modoDet = "CAMBIO">
<cfelse>
	<cfset modoDet = "ALTA">
</cfif>

<cfset filtro = "">
<cfif isdefined("Form.HYERVid") and Len(Trim(Form.HYERVid)) NEQ 0>
	<cfset navegacion = "HYERVid=" & Form.HYERVid>
<cfelse>
	<cfset navegacion = "">
</cfif>

<cfif modo EQ "CAMBIO">
	<cfquery name="rsEncabezado" datasource="#Session.DSN#">
<!---		select HYERVdescripcion, convert(varchar, a.HYERVfecha, 103) as HYERVfecha--->
		select HYERVdescripcion, <cf_dbfunction name ="to_datetime" args ="a.HYERVfecha"> as HYERVfecha
		
		from HYERelacionValoracion a
		where a.Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
		and a.HYERVid = <cfqueryparam cfsqltype="cf_sql_numeric" value="#Form.HYERVid#">
	</cfquery>
	
	<cfif modoDet EQ "CAMBIO">
		<cfquery name="rsDetalle" datasource="#Session.DSN#">
			select rtrim(a.RHPcodigo) as RHPcodigo, 
				coalesce(ltrim(rtrim(b.RHPcodigoext)),ltrim(rtrim(b.RHPcodigo))) as RHPcodigoext,
				rtrim(a.HYLAcodigo) as HYLAcodigo, 
				a.HYMgrado, 
				rtrim(a.HYIcodigo) as HYIcodigo, 
				rtrim(a.HYHEcodigo) as HYHEcodigo, 
				rtrim(a.HYHGcodigo) as HYHGcodigo, 
				a.HYIHgrado, 
				a.HYCPgrado, 
				rtrim(a.HYMRcodigo) as HYMRcodigo, 
				a.ptsHabilidad, 
				a.porcSP, 
				a.ptsSP, 
				a.ptsResp, 
				a.ptsTotal,
				b.RHPdescpuesto,
				a.HYERVjustificacion,
				a.HYHEvalor,
				a.HYHGvalor, 
				a.HYCPvalor, 
				a.HYLAvalor, 
				a.HYMvalor, 
				a.HYIvalor, 
				a.ts_rversion
			from HYDRelacionValoracion a, RHPuestos b
			where a.HYERVid = <cfqueryparam cfsqltype="cf_sql_numeric" value="#Form.HYERVid#">
			and a.HYDRVlinea = <cfqueryparam cfsqltype="cf_sql_numeric" value="#Form.HYDRVlinea#">
			and a.Ecodigo = <cfqueryparam cfsqltype="cf_sql_integer" value="#Session.Ecodigo#">
			and a.Ecodigo = b.Ecodigo
			and a.RHPcodigo = b.RHPcodigo
		</cfquery>
	</cfif>
	<!--- Al seleccionar la habilidad especializada se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsHabEspecializada" datasource="sifcontrol">
		select rtrim(HYHEcodigo) as HYHEcodigo, 
		{fn concat(rtrim(HYHEcodigo), {fn concat('. ', HYHEdescripcion)})} as HYHEdescripcion, HYHEdescalterna
		from HYHabilidadEspecializada
		order by HYHEcodigo, HYHEdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYHEcodigo")>
		<cfset Form.HYHEcodigo = rsDetalle.HYHEcodigo>
	<cfelseif not isdefined("Form.HYHEcodigo")>
		<cfset Form.HYHEcodigo = rsHabEspecializada.HYHEcodigo>
	</cfif>
	
	<!--- Al seleccionar la habilidad de gerencia se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsHabGerencia" datasource="sifcontrol">
		select rtrim(HYHGcodigo) as HYHGcodigo, 
		{fn concat(rtrim(HYHGcodigo),{fn concat('. ',HYHGdescripcion)})} as HYHGdescripcion,
		HYHGdescalterna
		from HYHabilidadGerencia
		order by HYHGcodigo, HYHGdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYHGcodigo")>
		<cfset Form.HYHGcodigo = rsDetalle.HYHGcodigo>
	<cfelseif not isdefined("Form.HYHGcodigo")>
		<cfset Form.HYHGcodigo = rsHabGerencia.HYHGcodigo>
	</cfif>
	
	<!--- Al seleccionar la interacción humana se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsInteraccionH" datasource="sifcontrol">
		select HYIHgrado, 
		{fn concat(<cf_dbfunction name="to_char" args="HYIHgrado">,{fn concat('. ',HYIHdescripcion)})}as HYIHdescripcion,
		 HYIHdescalterna
		from HYInteraccionHumana 
		order by HYIHgrado, HYIHdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYIHgrado")>
		<cfset Form.HYIHgrado = rsDetalle.HYIHgrado>
	<cfelseif not isdefined("Form.HYIHgrado")>
		<cfset Form.HYIHgrado = rsInteraccionH.HYIHgrado>
	</cfif>
	
	<!--- Se obtienen únicamente los puntos permitidos en habilidades de acuerdo a los 3 parámetros anteriores --->
	<!--- La selección de este valor no requiere submit pero se puede recuperar después de hacer el submit activado por otro combo --->
	<cfquery name="rsPtsHabilidades" datasource="sifcontrol">
		select HYTHpuntos
		from HYTHabilidades
		where HYHEcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYHEcodigo#">
		and HYHGcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYHGcodigo#">
		and HYIHgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYIHgrado#">
		order by HYTHpuntos
	</cfquery>
	<cfquery name="rsPtsHabilidades" datasource="sifcontrol">
		select HYTHpuntos
		from HYTHabilidades a, HYHabilidadEspecializada b, HYHabilidadGerencia c
		where a.HYHEcodigo=b.HYHEcodigo
		and a.HYHGcodigo=c.HYHGcodigo
		and a.HYHEcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYHEcodigo#">
		and a.HYHGcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYHGcodigo#">
		and a.HYIHgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYIHgrado#">	
		and a.HYTHrestrict = 1
		order by a.HYHEcodigo, a.HYHGcodigo, a.HYIHgrado
	</cfquery>

	<!--- Al seleccionar el marco de referencia se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsMarcoReferencia" datasource="sifcontrol">
		select rtrim(HYMRcodigo) as HYMRcodigo, 
		{fn concat(rtrim(HYMRcodigo),{fn concat('. ',HYMRdescripcion)})} as HYMRdescripcion, 
		HYMRdesclaterna
		from HYMarcoReferencia
		order by HYMRcodigo, HYMRdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYMRcodigo")>
		<cfset Form.HYMRcodigo = rsDetalle.HYMRcodigo>
	<cfelseif not isdefined("Form.HYMRcodigo")>
		<cfset Form.HYMRcodigo = rsMarcoReferencia.HYMRcodigo>
	</cfif>
	
	<!--- Al seleccionar la complejidad de pensamiento se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsComplejidadPens" datasource="sifcontrol">
		select HYCPgrado, 
		{fn concat(<cf_dbfunction name="to_char" args="HYCPgrado">,{fn concat('. ',HYCPdescripcion)})}as HYCPdescripcion, 
		HYCPdescalterna
		from HYComplejidadPensamiento 
		order by HYCPgrado, HYCPdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYCPgrado")>
		<cfset Form.HYCPgrado = rsDetalle.HYCPgrado>
	<cfelseif not isdefined("Form.HYCPgrado")>
		<cfset Form.HYCPgrado = rsComplejidadPens.HYCPgrado>
	</cfif>
	
	<!--- Se obtienen únicamente los porcentajes permitidos en solucion de problemas de acuerdo a los 2 parámetros anteriores --->
	<!--- La selección de este valor no requiere submit pero se puede recuperar después de hacer el submit activado por otro combo --->
	<cfquery name="rsPorcSolProblemas" datasource="sifcontrol">
		select HYTSPporcentaje
		from HYTSolucionProblemas
		where HYCPgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYCPgrado#">
		and HYMRcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYMRcodigo#">
		and HYTSrestrict = 1
		order by HYTSPporcentaje
	</cfquery>
	<cfif rsPorcSolProblemas.RecordCount EQ 0>
		<cfset vHYTSPporcentaje = -1>
	<cfelse>
		<cfset vHYTSPporcentaje = ValueList(rsPorcSolProblemas.HYTSPporcentaje, ',')>
	</cfif>
	<!--- Se obtienen únicamente los puntos permitidos en el cuadro auxiliar de solucion de problemas dentro del rango de los puntos permitidos en habilidades y los porcentajes permitidos en solución de problemas --->
	<!--- La selección de este valor no requiere submit pero se puede recuperar después de hacer el submit activado por otro combo --->
	<cfif rsPtsHabilidades.recordCount>
		<cfquery name="rsPtsSolProblemas" datasource="sifcontrol">
			select HYTAptshab, HYTAporcentaje, HYTApts
			from HYTASolucionProblemas
			where HYTAptshab in (<cfqueryparam cfsqltype="cf_sql_integer" list="yes" separator="," value="#ValueList(rsPtsHabilidades.HYTHpuntos, ',')#">)
			and HYTAporcentaje in (<cfqueryparam cfsqltype="cf_sql_float" list="yes" separator="," value="#vHYTSPporcentaje#">)
			order by HYTAptshab, HYTAporcentaje
		</cfquery>
		
		<!--- Obtención del valor mínimo y máximo posible --->
		<cfset MinSolProblemas = ArrayMin(ListToArray(ValueList(rsPtsSolProblemas.HYTApts, ','), ','))>
		<cfset MaxSolProblemas = ArrayMax(ListToArray(ValueList(rsPtsSolProblemas.HYTApts, ','), ','))>
	</cfif>
	<!--- Al seleccionar la libertad de actuar se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsLibertadActuar" datasource="sifcontrol">
		select rtrim(HYLAcodigo) as HYLAcodigo, 
			{fn concat(rtrim(HYLAcodigo), {fn concat('. ',HYLAdescripcion)})}  as HYLAdescripcion, 
			HYLAdescalterna
		from HYLibertadActuar
		order by HYLAcodigo, HYLAdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYLAcodigo")>
		<cfset Form.HYLAcodigo = rsDetalle.HYLAcodigo>
	<cfelseif not isdefined("Form.HYLAcodigo")>
		<cfset Form.HYLAcodigo = rsLibertadActuar.HYLAcodigo>
	</cfif>
	
	<!--- Al seleccionar la magnitud se requiere submit y se puede recuperar el valor que tenía antes del submit --->
	<cfquery name="rsMagnitud" datasource="sifcontrol">
		select HYMgrado,
			{fn concat(<cf_dbfunction name="to_char" args="HYMgrado">,{fn concat('. ',HYMdescripcion)})} as HYMdescripcion
		from HYMagnitud 
		order by HYMgrado, HYMdescripcion
	</cfquery>
	<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYMgrado")>
		<cfset Form.HYMgrado = rsDetalle.HYMgrado>
	<cfelseif not isdefined("Form.HYMgrado")>
		<cfset Form.HYMgrado = rsMagnitud.HYMgrado>
	</cfif>

	<!--- Se obtienen únicamente los impactos permitidos de acuerdo a lo escogido en magnitud --->
	<!--- La selección de este valor no requiere submit pero se puede recuperar después de hacer el submit activado por otro combo --->
	<cfquery name="rsImpacto" datasource="sifcontrol">
		select rtrim(HYIcodigo) as HYIcodigo, 
			   {fn concat(rtrim(HYIcodigo),{fn concat('. ',HYIdescripcion)})} as HYIdescripcion,
			   case when HYMgrado = 0 and HYIcodigo = 'N' then 1
			        when HYMgrado = 0 and HYIcodigo = 'M' then 2
			        when HYMgrado = 0 and HYIcodigo = 'I' then 3
			        when HYMgrado = 0 and HYIcodigo = 'C' then 4
			        when HYMgrado <> 0 and HYIcodigo = 'R' then 5
			        when HYMgrado <> 0 and HYIcodigo = 'C' then 6
			        when HYMgrado <> 0 and HYIcodigo = 'S' then 7
			        when HYMgrado <> 0 and HYIcodigo = 'P' then 8
					else 9
				end as Orden
		from HYImpacto
		where HYMgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYMgrado#">
		order by Orden
	</cfquery>

	<!--- Se obtienen únicamente los puntos permitidos en responsabilidad de acuerdo a la libertad de actuar y a la magnitud escogida --->
	<!--- Posteriormente los valores se filtran dinámicamente de acuerdo al impacto escogido --->
	<!--- La selección de este valor no requiere submit pero se puede recuperar después de hacer el submit activado por otro combo --->
	<cfquery name="rsPtsResponsabilidad" datasource="sifcontrol">
		select rtrim(HYIcodigo) as HYIcodigo, HYTRvalor
		from HYTResponsabilidad
		where HYLAcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYLAcodigo#">
		and HYMgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYMgrado#">
		order by HYIcodigo, HYTRvalor
	</cfquery>
	<cfif rsPtsHabilidades.recordCount>
		<!--- Obtención del valor mínimo y máximo posible --->
		<cfset MinResponsabilidad = ArrayMin(ListToArray(ValueList(rsPtsResponsabilidad.HYTRvalor, ','), ','))>
		<cfset MaxResponsabilidad = ArrayMax(ListToArray(ValueList(rsPtsResponsabilidad.HYTRvalor, ','), ','))>
	
		<!--- Averiguar los valores mínimo y máximo del rango de valores de intervalos --->
		<cfset MinIntervalo = Min(MinSolProblemas, MinResponsabilidad)>
		<cfset MaxIntervalo = Max(MaxSolProblemas, MaxResponsabilidad)>
		<!--- Rango de Valores de Intervalos Permitidos --->
		<cfquery name="rsValoresIntervalos" datasource="sifcontrol">
			select HYVIvalor
			from HYValoresIntervalos
			where HYVIvalor between #MinIntervalo# and #MaxIntervalo#
			order by HYVIvalor
		</cfquery>
	</cfif>
	<!--- Se obtienen todas las ternas resultantes para un perfil dados: porcentaje de solución de problemas, puntos totales de responsabilidad, puntos totales de solución de problemas --->
	<!--- Estas ternas se muestran dinámicamente en la pantalla --->
	<cfquery name="rsPtsPerfiles" datasource="sifcontrol">
		select b.HYTPporcentaje, rtrim(b.HYTPresp) as HYTPresp, (b.HYTPcol-1) as HYTPcol, b.HYTPptshab
		from HYTSolucionProblemas a, HYTPerfiles b
		where a.HYCPgrado = <cfqueryparam cfsqltype="cf_sql_integer" value="#Form.HYCPgrado#">
		and a.HYMRcodigo = <cfqueryparam cfsqltype="cf_sql_char" value="#Form.HYMRcodigo#">
		and a.HYTSPporcentaje = b.HYTPporcentaje
		and a.HYTSrestrict = 1
		order by b.HYTPporcentaje, b.HYTPresp, b.HYTPcol, b.HYTPptshab
	</cfquery>
	
	
</cfif>

<script language="JavaScript" src="/cfmx/sif/js/qForms/qforms.js">//</script>
<script language="javascript" type="text/javascript" src="/cfmx/rh/js/utilesMonto.js">//utiles</script>
<script language="javascript" type="text/javascript">
	<!--//
	// specify the path where the "/qforms/" subfolder is located
	qFormAPI.setLibraryPath("/cfmx/sif/js/qForms/");
	// loads all default libraries
	qFormAPI.include("*");

	function validaForm(f) {
		<cfif modo EQ "CAMBIO">
		f.obj.RHPcodigo.disabled = false;
		if (f.obj.PtsPerfil.value == 'NO DEFINIDO' || f.obj.PtsPerfil.value == '') {
			alert('<cfoutput>#MSG_NOHayUnPerfilDePuestoDEFINIDODeAcuerdoALosValoresEscogidosPorFavorCambieLosValoresSeleccionadosEnLaValoracionDelPuestoAntesDeContinuar#</cfoutput>.');
			return false;
		}
		</cfif>	
		return true;
	}

	function doConlisImport() {
		window.open("RelacionPuestos-import.cfm", "ImportarRelacion");
	}

	<cfoutput>
	<cfif modo EQ "CAMBIO">

		function doConlisPuesto() {
			var params ="";
			params = "?form=form1&name=RHPcodigo&nameExt=RHPcodigoext&desc=RHPdescpuesto&HYERVid=#Form.HYERVid#";
			window.open("/cfmx/rh/admin/catalogos/conlisPuestos.cfm"+params,"ListaPuestos", "top=250,left=200,width=650,height=400");
		}
		//Obtiene la descripción con base al código
		function TraePuesto(dato) {
			var params ="";
			params = "?RHPcodigoext="+dato+"&name=RHPcodigo&nameExt=RHPcodigoext&desc=RHPdescpuesto&HYERVid=#Form.HYERVid#&form=form1";
			if (dato!="") {
				var fr = document.getElementById("frpuesto");
				fr.src = "/cfmx/rh/admin/catalogos/qryGetPuestos.cfm"+params;
			}
			return;
		}
	
		var pts = new Object();
		<cfset hab = "">
		<cfif rsPtsHabilidades.recordCount>
		<cfloop query="rsPtsSolProblemas">
			<cfif hab NEQ rsPtsSolProblemas.HYTAptshab>
				<cfset hab = rsPtsSolProblemas.HYTAptshab>
				pts["#hab#"] = new Object();
			</cfif>
			<cfset sp = rsPtsSolProblemas.HYTAporcentaje>
			<cfset spPts = rsPtsSolProblemas.HYTApts>
			pts["#hab#"]["#sp#"] = "#spPts#";
		</cfloop>
		</cfif>
		var ptsResp = new Object();
		<cfset resp = "">
		<cfloop query="rsPtsResponsabilidad">
			<cfif resp NEQ rsPtsResponsabilidad.HYIcodigo>
				<cfset resp = rsPtsResponsabilidad.HYIcodigo>
				ptsResp["#resp#"] = new Array();
			</cfif>
			<cfset respPts = rsPtsResponsabilidad.HYTRvalor>
			ptsResp["#resp#"][ptsResp["#resp#"].length] = "#respPts#";
		</cfloop>
		<cfif rsPtsHabilidades.recordCount>
			var intervalo = new Object();
			<cfloop query="rsValoresIntervalos">
				intervalo["#HYVIvalor#"] = #CurrentRow#;
			</cfloop>
	
			var ptsPerfil = new Object();
			<cfset porc = "">
			<cfset niv = "">
			<cfloop query="rsPtsPerfiles">
				<cfif porc NEQ rsPtsPerfiles.HYTPporcentaje>
					<cfset porc = rsPtsPerfiles.HYTPporcentaje>
					<cfset niv = "">
					ptsPerfil["#porc#"] = new Object();
				</cfif>
				<cfif niv NEQ rsPtsPerfiles.HYTPresp>
					<cfset niv = rsPtsPerfiles.HYTPresp>
					ptsPerfil["#porc#"]["#niv#"] = new Array();
				</cfif>
				<cfset ptsidx = rsPtsPerfiles.HYTPcol>
				<cfset ptsPf = rsPtsPerfiles.HYTPptshab>
				ptsPerfil["#porc#"]["#niv#"][#ptsidx#] = "#ptsPf#";
			</cfloop>
		</cfif>		
		function getInterval(f) {
			var P = "" + f.HYTSPporcentaje.value;
			var R = "" + f.HYTRvalor.value;
			var SP = "" + f.HYTApts.value;
			var result = intervalo[R] - intervalo[SP];
			var absResult = Math.abs(result);
			if (result > 0 && result <= 4) {
				var resp = "R" + absResult;
				var terna = resp + ' - ' + ptsPerfil[P][resp].join(', ');
			} else if (result < 0 && result >= -4) {
				var resp = "SP" + absResult;
				var terna = resp + ' - ' + ptsPerfil[P][resp].join(', ');
			} else if (result == 0) {
				var resp = "NIVELADO";
				var terna = resp + ' - ' + ptsPerfil[P][resp].join(', ');
			} else {
				var terna = "NO DEFINIDO";
			}
			f.PtsPerfil.value = terna;
		}

		function chgValues(f) {
			f.action = '#GetFileFromPath(GetTemplatePath())#';
			f.RHPdescpuesto.disabled = false;
			f.submit();
		}
		function calcPts(f) {
			var pts1 = parseInt(f.HYTHpuntos.value, 10);
			var pts2 = parseInt(f.HYTApts.value, 10);
			var pts3 = parseInt(f.HYTRvalor.value, 10);
			var pts = pts1 + pts2 + pts3;
			f.PtsTotales.value = pts;
			getInterval(f);
		}

		function getPts(f) {
			if (f.HYTHpuntos != undefined && f.HYTSPporcentaje != undefined){
			var hab = f.HYTHpuntos.value;
			var sp = f.HYTSPporcentaje.value;
			f.HYTApts.value = pts[hab][sp];
			calcPts(f);
			}
		}
		
		function refill(f) {
			var imp = f.HYIcodigo.value;
			var a = f.HYTRvalor;
			while (a.length > 0) {
				a.options[a.length-1] = null;
			}
			for (var i=0; i < ptsResp[imp].length; i++) {
				a.options[i] = new Option(ptsResp[imp][i], ptsResp[imp][i]);
			<cfif modoDet EQ "CAMBIO" and not isdefined("Form.HYTRvalor")>
				if (ptsResp[imp][i] == "#rsDetalle.ptsResp#") {
					a.selectedIndex = i;
				}
			<cfelseif isdefined("Form.HYTRvalor")>
				if (ptsResp[imp][i] == "#Form.HYTRvalor#") {
					a.selectedIndex = i;
				}
			</cfif>
			}
			<!--- VALIDACIONES PARA TOMAR EN CUENTA LOS CALORES + - o 0 
				PARA SUGERIR LOS PUNTOS DE LAS RESPONSABILIDADES--->
			<cfif isdefined('form.HYMvalor') and isdefined('form.HYLAvalor') 
				and ((form.HYMvalor EQ  '+' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '-') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '+') )>
				a.selectedIndex = 2;
			<cfelseif isdefined('form.HYMvalor') and isdefined('form.HYLAvalor') 
				and ((form.HYMvalor EQ  '-' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '+') 
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '-') 
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '-') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '-') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '-') 
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '0') 
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '-'))>			
			  	a.selectedIndex = 0;
			<cfelseif isdefined('form.HYMvalor') and isdefined('form.HYLAvalor') 
				and ((form.HYMvalor EQ  '-' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '0')
					or (form.HYMvalor EQ  '-' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '+')
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '+')
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '-' and form.HYIvalor EQ '0')
					or (form.HYMvalor EQ  '+' and form.HYLAvalor EQ '0' and form.HYIvalor EQ '-')
					or (form.HYMvalor EQ  '0' and form.HYLAvalor EQ '+' and form.HYIvalor EQ '-'))>
				a.selectedIndex = 1;
			</cfif>
			getPts(f);
		}
		
	</cfif>
	</cfoutput>
	
	//-->
</script>

