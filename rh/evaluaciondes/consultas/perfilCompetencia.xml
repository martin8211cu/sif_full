	<parameter class="java.math.BigDecimal" isForPrompting="false" name="Ecodigo">
		<defaultValueExpression><![CDATA[new java.math.BigDecimal(28)]]></defaultValueExpression>
	</parameter>
	<parameter class="java.math.BigDecimal" isForPrompting="false" name="id_centro"/>
	<parameter class="java.math.BigDecimal" isForPrompting="false" name="RHEEid">
		<defaultValueExpression><![CDATA[new java.math.BigDecimal(26)]]></defaultValueExpression>
	</parameter>
	<queryString><![CDATA[select
	c.CFid, evn.RHEEid , c.RHPid, c2.RHPid RHPid2,
	isnull (evn.RHIHid, 0) RHIHid, isnull (evn.RHICid, 0) RHICid,
	c.CFidresp, c.CFdescripcion, eve.RHEEdescripcion, 
	convert (numeric(8,4), avg (evn.RHNEDpromedio)) prom1, convert (numeric(8,4), 0.00) prom2
into #t
from LineaTiempo a, RHPlazas b, CFuncional c, CFuncional c2,  RHListaEvalDes evd,
	RHEEvaluacionDes eve, RHNotasEvalDes evn,
	DatosEmpleado emp
where eve.Ecodigo = $P{Ecodigo}
  and eve.RHEEestado = 3
  and eve.RHEEid = $P{RHEEid}
  and evd.Ecodigo = $P{Ecodigo}
  and eve.RHEEid = evd.RHEEid
  and evd.RHEEid = eve.RHEEid
  and evn.RHEEid = evd.RHEEid
  and evn.DEid = evd.DEid
  and getdate() between a.LTdesde and a.LThasta 
  and emp.Ecodigo = eve.Ecodigo
  and eve.Ecodigo = a.Ecodigo
  and emp.DEid = evd.DEid
  and a.DEid = evd.DEid
  and a.Ecodigo = evd.Ecodigo
  and a.DEid = emp.DEid
  and a.RHPid = b.RHPid
  and eve.Ecodigo = c.Ecodigo
  and eve.RHEEid = evd.RHEEid
  and b.CFid = c.CFid
  and c.CFidresp *= c2.CFid
  and evd.DEid = emp.DEid
  and evn.DEid = evd.DEid
  and emp.DEid = a.DEid
  and (evn.RHNEDnotajefe is not null or evn.RHNEDnotaauto is not null or evn.RHNEDpromotros is not null)
 and c.CFid = $P{id_centro}
group by
	c.CFid, evn.RHEEid , c.RHPid, c2.RHPid,
	evn.RHIHid, evn.RHICid,
	c.CFidresp, c.CFdescripcion, eve.RHEEdescripcion

update #t
set prom2 = isnull ((select avg (RHNEDpromedio)
	from RHNotasEvalDes n
	where n.RHEEid = $P{RHEEid}
	  and (n.RHICid = #t.RHICid or #t.RHICid = 0)
	  and (n.RHIHid = #t.RHIHid or #t.RHIHid = 0)), 0)

select
	CFid, RHEEid , RHPid, RHPid2,
	isnull (hab.RHHid, 0) RHHid, isnull (con.RHCid, 0) RHCid,
	CFidresp, CFdescripcion, RHEEdescripcion,
	avg (prom1) prom1, avg (prom2) prom2
into #t2
from #t, RHIHabilidad hab, RHIConocimiento con
where hab.RHIHid =* #t.RHIHid
  and con.RHICid =* #t.RHICid

group by
	CFid, RHEEid , RHPid, RHPid2,
	isnull (hab.RHHid, 0), isnull (con.RHCid, 0),
	CFidresp, CFdescripcion, RHEEdescripcion



select
	cia.Edescripcion, 
	NombreJefe = isnull((select
		DEnombre || ' ' || DEapellido1 || ' ' || DEapellido2 from DatosEmpleado
		where DEid = isnull (
			(select min(l.DEid) from LineaTiempo l where l.RHPid = t.RHPid  and getdate() between l.LTdesde and l.LThasta),
			(select min(l.DEid) from LineaTiempo l where l.RHPid = t.RHPid2 and getdate() between l.LTdesde and l.LThasta))),'No Asignado'),
	coalesce ( habil.RHHdescripcion, conoc.RHCdescripcion) descripcion,
	t.*
from #t2 t,
	RHHabilidades habil, RHConocimientos conoc, Empresas cia
where habil.RHHid =* t.RHHid
  and conoc.RHCid =* t.RHCid
  and cia.Ecodigo = $P{Ecodigo}
order by descripcion

drop table #t, #t2]]></queryString>
