	<queryString><![CDATA[select  evn.RHEEid ,  coalesce (habil.RHHdescripcion  , conoc.RHCdescripcion  )  as RHHdescripcion , conoc.RHCdescripcion  as RHCdescripcion,
 c.CFidresp, c.CFdescripcion, cia.Edescripcion as Edescripcion, eve.RHEEdescripcion as RHEEdescripcion,
 NombreJefe = isnull((select
  DEnombre || ' ' || DEapellido1 || ' ' || DEapellido2 from DatosEmpleado
  where DEid = isnull (
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c.RHPid and
getdate() between l.LTdesde and l.LThasta),
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c2.RHPid and
getdate() between l.LTdesde and l.LThasta))),'No Asignado'),

 emp.DEidentificacion cedula,
 emp.DEnombre || ' ' || emp.DEapellido1 || ' ' || emp.DEapellido2 as NombreEmpleado,  coalesce (hab.RHIHdescripcion, con.RHICdescripcion) Habilidad,

 evn.RHNEDnotajefe, evn.RHNEDnotaauto, evn.RHNEDpromotros, evn.RHNEDpromedio 
from LineaTiempo a, RHPlazas b, CFuncional c, CFuncional c2,  RHListaEvalDes evd,
	 RHEEvaluacionDes eve, RHNotasEvalDes evn,  RHIHabilidad hab, 
	RHIConocimiento con, DatosEmpleado emp, Empresas cia ,  RHHabilidades habil, RHConocimientos conoc
where eve.Ecodigo = $P{Ecodigo}
  and eve.RHEEestado = 3
  and eve.RHEEid = $P{RHEEid}
  and evd.Ecodigo = $P{Ecodigo} 
  and eve.RHEEid = evd.RHEEid
  and evd.RHEEid = eve.RHEEid
  and evn.RHEEid = evd.RHEEid
  and evn.DEid = evd.DEid
  and getdate() between a.LTdesde and a.LThasta 
  and emp.Ecodigo = eve.Ecodigo
  and eve.Ecodigo = a.Ecodigo
  and emp.DEid = evd.DEid
  and a.DEid = evd.DEid
  and a.Ecodigo = evd.Ecodigo
  and a.DEid = emp.DEid
  and a.RHPid = b.RHPid
  and eve.Ecodigo = c.Ecodigo
  and eve.Ecodigo = cia.Ecodigo
  and eve.RHEEid = evd.RHEEid
  and b.CFid = c.CFid
  and c.CFidresp *= c2.CFid
  and evd.DEid = emp.DEid
  and evn.DEid = evd.DEid
  and hab.RHIHid =* evn.RHIHid
  and con.RHICid =* evn.RHICid
  and emp.DEid = a.DEid
  and hab.RHHid *= habil.RHHid
  and con.RHCid  *=  conoc.RHCid
  and (evn.RHNEDnotajefe is not null or evn.RHNEDnotaauto is not null or evn.RHNEDpromotros is not null)
 and c.CFid = (case when $P{id_centro} is null  then c.CFid  else $P{id_centro} end )
order by CFdescripcion, cedula, RHHdescripcion, Habilidad]]></queryString>
