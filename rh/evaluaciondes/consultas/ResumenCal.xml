	<queryString><![CDATA[select
 c.CFidresp, c.CFdescripcion, cia.Edescripcion as Edescripcion, eve.RHEEdescripcion as RHEEdescripcion,
 NombreJefe = isnull((select
  DEnombre || ' ' || DEapellido1 || ' ' || DEapellido2 from DatosEmpleado
  where DEid = isnull (
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c.RHPid and
getdate() between l.LTdesde and l.LThasta),
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c2.RHPid and
getdate() between l.LTdesde and l.LThasta))),'No Asignado'),

 emp.DEidentificacion cedula,
 emp.DEnombre || ' ' || emp.DEapellido1 || ' ' || emp.DEapellido2 NombreEmpleado, 
 round(evd.RHLEnotajefe,2) as RHLEnotajefe, round(evd.RHLEnotaauto,2) as RHLEnotaauto,
 round(evd.RHLEpromotros,2) as RHLEpromotros, round(evd.promglobal,2) as promglobal
from LineaTiempo a, RHPlazas b, CFuncional c, CFuncional c2,  RHListaEvalDes evd,
 RHEEvaluacionDes eve, DatosEmpleado emp, Empresas cia  

where eve.Ecodigo = $P{Ecodigo}
  and evd.RHEEid = $P{RHEEid}
  and eve.RHEEestado = 3
  and getdate() between a.LTdesde and a.LThasta
  and emp.Ecodigo = eve.Ecodigo
  and eve.Ecodigo = a.Ecodigo
  and a.DEid = emp.DEid
  and a.RHPid = b.RHPid
  and eve.Ecodigo = c.Ecodigo
  and eve.Ecodigo = cia.Ecodigo
  and eve.RHEEid = evd.RHEEid
  and b.CFid = c.CFid
  and c.CFidresp *= c2.CFid
  and evd.DEid = emp.DEid
  --and evd.RHLEnotajefe is not null
order by CFdescripcion, cedula, RHEEdescripcion]]></queryString>
