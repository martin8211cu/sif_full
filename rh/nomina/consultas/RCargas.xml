	<queryString><![CDATA[select  emp.Ecodigo, 
 emp.Edescripcion as Empresa, 
 ec.ECid,
 ec.ECcodigo,
 ec.ECdescripcion,
 sn.SNcodigo,
 sn.SNnumero,
 sn.SNnombre,
 cp.CPcodigo, 
 convert(varchar,cp.CPdesde,103) as CPdesde, 
 convert(varchar,cp.CPhasta,103) as CPhasta,  
 de.DEidentificacion,
 de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' + de.DEnombre as DEnombre,
 b.CCvaloremp,
 b.CCvalorpat,
 (select rtrim(cf.CFcodigo) || ' - ' || rtrim(cf.CFdescripcion)
 from PagosEmpleado pe, RHPlazas pl, CFuncional cf 
 where pe.RCNid = b.RCNid 
   and pe.DEid = b.DEid 
   and pe.PEdesde = (select max(pe2.PEdesde) from PagosEmpleado pe2 where pe2.RCNid = pe.RCNid and pe2.DEid = pe.DEid)
   and pl.RHPid = pe.RHPid 
   and cf.CFid = pl.CFid
 ) as CFdescripcion
from RCalculoNomina a, CargasCalculo b, CargasEmpleado c, 
ECargas ec, DCargas dc, CalendarioPagos cp, DatosEmpleado de, 
SNegocios sn, Empresas emp
where a.RCNid = 1107
  and a.Ecodigo = 1
  and a.Ecodigo = emp.Ecodigo
  and cp.CPid = a.RCNid
  and a.RCNid = b.RCNid
  and b.DClinea = c.DClinea
  and b.DEid = c.DEid
  and c.DClinea = dc.DClinea
  and dc.ECid = ec.ECid
  and dc.Ecodigo = ec.Ecodigo
  and a.Ecodigo = ec.Ecodigo
  and b.DEid = de.DEid
  and dc.Ecodigo = sn.Ecodigo
  and dc.SNcodigo = sn.SNcodigo
  and ec.ECid = isnull(null, ec.ECid)
  and b.DEid = isnull(4839, b.DEid)
order by ec.ECcodigo, de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' || de.DEnombre]]></queryString>
