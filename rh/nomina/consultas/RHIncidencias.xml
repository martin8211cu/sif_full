	<queryString><![CDATA[
 

 
select 
 ci.CIcodigo Incidencia,
 substring(ci.CIdescripcion, 1, 30) Descripcion,
 substring(e.DEapellido1 || ' ' || e.DEapellido2 || ', ' || e.DEnombre , 1, 40) Nombre,
 substring(e.DEidentificacion, 1, 15) Cedula, 
 a.ICfecha as Fecha,
 cp.CPcodigo, 
 cp.CPdesde as CPdesde, 
 cp.CPhasta as CPhasta,  
 emp.Edescripcion,
 z.RCDescripcion,
 sum(a.ICvalor) Valor,
 sum(a.ICmontores) Monto
 $P{fechal} as FechaHoy

from HIncidenciasCalculo a
	, DatosEmpleado e
	, CIncidentes ci
	, CalendarioPagos cp
	, Empresas emp
	, HRCalculoNomina z


where a.RCNid = $P{RCNid}
   and a.CIid = coalesce($P{CIidA}, a.CIid)
   and e.DEid = a.DEid
   and ci.CIid = a.CIid
   and a.RCNid = cp.CPid
   and cp.Ecodigo = emp.Ecodigo
  and z.RCNid = a.RCNid

group by 
 ci.CIcodigo,
 substring(ci.CIdescripcion, 1, 30),
 substring(e.DEapellido1 || ' ' || e.DEapellido2 || ', ' || e.DEnombre , 1, 40),
 substring(e.DEidentificacion, 1, 15), 
 a.ICfecha,
 cp.CPcodigo, 
 cp.CPdesde, 
 cp.CPhasta,
 emp.Edescripcion,
 z.RCDescripcion]]></queryString>
