	<queryString><![CDATA[select
	a.RCDescripcion,
	emp.Ecodigo, 
	emp.Edescripcion as Empresa, 
	d.TDid,
	d.TDcodigo,
	d.TDdescripcion,
	sn.SNcodigo,
	sn.SNnumero,
	sn.SNnombre,
	cp.CPcodigo, 
	cp.CPdesde as CPdesde, 
	cp.CPhasta as CPhasta,  
	de.DEidentificacion,
	de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' || de.DEnombre as DEnombre,
	b.DCvalor as DCvalor,
	case when c.Dcontrolsaldo = 1 then b.DCsaldo else null end DCsaldo,
	(select rtrim(cf.CFcodigo) || ' - ' || rtrim(cf.CFdescripcion)
	from HPagosEmpleado pe, RHPlazas pl, CFuncional cf 
	where pe.RCNid = b.RCNid 
	  and pe.DEid = b.DEid 
	  and pe.PEdesde = (select max(pe2.PEdesde) from HPagosEmpleado pe2 where pe2.RCNid = pe.RCNid and pe2.DEid = pe.DEid)
	  and pl.RHPid = pe.RHPid 
	  and cf.CFid = pl.CFid
	) as CFdescripcion,
	$P{fechal} as fecha, 
	c.Dreferencia
from HRCalculoNomina a, HDeduccionesCalculo b, 
DeduccionesEmpleado c, TDeduccion  d, CalendarioPagos cp,
DatosEmpleado de, SNegocios sn, Empresas emp
where a.RCNid = $P{RCNid}
  and a.Ecodigo = $P{Ecodigo}
  and a.Ecodigo = emp.Ecodigo
  and cp.CPid = a.RCNid
  and a.RCNid = b.RCNid
  and b.Did = c.Did
  and b.DEid = de.DEid
  and c.TDid = d.TDid
  and c.Ecodigo = a.Ecodigo
  and c.Ecodigo = sn.Ecodigo
  and c.SNcodigo = sn.SNcodigo
  and d.Ecodigo = a.Ecodigo
  and d.TDid = coalesce($P{TDid}, d.TDid)
order by d.TDcodigo, sn.SNcodigo, de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' || de.DEnombre]]></queryString>
