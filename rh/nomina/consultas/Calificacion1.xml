	<queryString><![CDATA[select
 c.CFidresp, c.CFdescripcion, cia.Edescripcion as Edescripcion, eve.RHEEdescripcion as RHEEdescripcion,
 NombreJefe = (select
  DEnombre || ' ' || DEapellido1 || ' ' || DEapellido2 from DatosEmpleado
  where DEid = isnull (
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c.RHPid and
getdate() between l.LTdesde and l.LThasta),
   (select min(l.DEid) from LineaTiempo l where l.RHPid = c2.RHPid and
getdate() between l.LTdesde and l.LThasta))),

 emp.DEidentificacion cedula,
 emp.DEnombre || ' ' || emp.DEapellido1 || ' ' || emp.DEapellido2 NombreEmpleado,  coalesce (hab.RHIHdescripcion, con.RHICdescripcion) Habilidad,

 evn.RHNEDnotajefe, evn.RHNEDnotaauto, evn.RHNEDpromotros, evn.RHNEDpromedio from LineaTiempo a, RHPlazas b, CFuncional c, CFuncional c2,  RHListaEvalDes evd,
 RHEEvaluacionDes eve, RHNotasEvalDes evn,  RHIHabilidad hab, RHIConocimiento con, DatosEmpleado emp, Empresas cia where getdate() between a.LTdesde and a.LThasta
  and a.RHPid = b.RHPid
  and b.Ecodigo = $P{Ecodigo}
  and evn.RHEEid = $P{RHEEid}
  and b.Ecodigo = c.Ecodigo
  and b.Ecodigo = cia.Ecodigo
  and b.CFid = c.CFid
  and c.CFidresp *= c2.CFid
  and evd.DEid = a.DEid
  and eve.RHEEid = evd.RHEEid
  and eve.RHEEestado = 3
  and evn.RHEEid = evd.RHEEid
  and evn.DEid = evd.DEid
  and hab.RHIHid =* evn.RHIHid
  and con.RHICid =* evn.RHICid
  and emp.DEid = a.DEid
]]></queryString>
