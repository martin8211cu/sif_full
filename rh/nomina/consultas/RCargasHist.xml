	<queryString><![CDATA[select
 a.RCDescripcion,
 emp.Ecodigo, 
 emp.Edescripcion as Empresa, 
 ec.ECid,
 ec.ECcodigo,
 ec.ECdescripcion,
 sn.SNcodigo,
 sn.SNnumero,
 sn.SNnombre,
 cp.CPcodigo, 
 cp.CPdesde as CPdesde, 
 cp.CPhasta as CPhasta,  
 de.DEidentificacion,
 de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' || de.DEnombre as DEnombre,
 b.CCvaloremp,
 b.CCvalorpat,
 (select rtrim(cf.CFcodigo) || ' - ' || rtrim(cf.CFdescripcion)
 from HPagosEmpleado pe, RHPlazas pl, CFuncional cf 
 where pe.RCNid = b.RCNid 
   and pe.DEid = b.DEid 
   and pe.PEdesde = (select max(pe2.PEdesde) from HPagosEmpleado pe2 where pe2.RCNid = pe.RCNid and pe2.DEid = pe.DEid)
   and pl.RHPid = pe.RHPid 
   and cf.CFid = pl.CFid
 ) as CFdescripcion, $P{fechal} as fecha,
	dc.DCcodigo
from HRCalculoNomina a, HCargasCalculo b, CargasEmpleado c,
 ECargas ec, DCargas dc, CalendarioPagos cp, 
DatosEmpleado de, SNegocios sn, Empresas emp
where a.RCNid = $P{RCNid}
  and a.Ecodigo = $P{Ecodigo}
  and a.Ecodigo = emp.Ecodigo
  and cp.CPid = a.RCNid
  and a.RCNid = b.RCNid
  and b.DClinea = c.DClinea
  and b.DEid = c.DEid
  and c.DClinea = dc.DClinea
  and dc.ECid = ec.ECid
  and dc.Ecodigo = ec.Ecodigo
  and a.Ecodigo = ec.Ecodigo
  and b.DEid = de.DEid
  and dc.Ecodigo = sn.Ecodigo
  and dc.SNcodigo = sn.SNcodigo
  and ec.ECid = coalesce($P{ECid}, ec.ECid)
order by ec.ECcodigo, de.DEapellido1 || ' ' ||  de.DEapellido2 || ' ' || de.DEnombre]]></queryString>
